---
export const prerender = true;
import HubPageLayout from '../../../components/hub/HubPageLayout.astro';
import { loadLatestScores } from '../../../lib/scores';
import { getSafestForFamilies } from '../../../lib/hub-data';
import { useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

const lang: Lang = 'en';
const t = useTranslations(lang);
const countries = loadLatestScores();
const ranked = getSafestForFamilies(countries, 20);
const title = t('hub.families.title' as any);
const description = t('hub.families.description' as any);
const intro = t('hub.families.intro' as any);
const canonicalUrl = 'https://isitsafetotravel.org/en/safest-for-families/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  description,
  url: canonicalUrl,
  numberOfItems: ranked.length,
  itemListElement: ranked.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name[lang],
    url: `https://isitsafetotravel.org/en/country/${c.iso3.toLowerCase()}/`,
  })),
};
---
<HubPageLayout
  lang={lang}
  title={title}
  description={description}
  intro={intro}
  jsonLd={jsonLd}
  countries={ranked}
/>
