---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import SafetyMap from '../../components/SafetyMap.astro';
import GlobalScoreBanner from '../../components/GlobalScoreBanner.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { routes } from '../../i18n/ui';
import { buildHomepageJsonLd, buildOrganizationJsonLd, buildDatasetJsonLd } from '../../lib/seo';
import { loadLatestScores } from '../../lib/scores';

const lang: Lang = 'en';
const t = useTranslations(lang);
const countries = loadLatestScores().sort((a, b) => a.name[lang].localeCompare(b.name[lang]));

const siteUrl = 'https://isitsafetotravel.org';
const dateModified = new Date().toISOString().split('T')[0];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { ...buildHomepageJsonLd(siteUrl, lang, dateModified), '@context': undefined },
    { ...buildOrganizationJsonLd(siteUrl), '@context': undefined },
    buildDatasetJsonLd(),
  ],
};
---

<Base lang={lang} jsonLd={jsonLd} ogImage="/og/default.png">
  <section class="flex flex-col" style="height: calc(100dvh - 4rem);">
    <div class="text-center pt-4 pb-2 px-4">
      <h1 class="font-heading text-2xl md:text-3xl font-bold text-sand-800 dark:text-sand-100">
        {t('hero.title')}
      </h1>
      <p class="text-sm md:text-base text-sand-500 dark:text-sand-400 mt-1">
        {t('map.tagline')}
      </p>
    </div>
    <GlobalScoreBanner lang={lang} />
    <div class="flex-1 min-h-0 overflow-hidden">
      <SafetyMap lang={lang} />
    </div>
  </section>
  {/* Popular Rankings */}
  <section class="max-w-6xl mx-auto px-4 py-8">
    <h2 class="text-xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">{t('nav.rankings' as any)}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
      {[
        { key: 'hub.safest_countries.title', route: routes[lang]['safest-countries'] },
        { key: 'hub.dangerous_countries.title', route: routes[lang]['most-dangerous-countries'] },
        { key: 'hub.region.europe.title', route: `${routes[lang]['regions']}/europe` },
        { key: 'hub.solo_travelers.title', route: routes[lang]['safest-for-solo-travelers'] },
        { key: 'hub.families.title', route: routes[lang]['safest-for-families'] },
        { key: 'hub.countries_to_avoid.title', route: routes[lang]['countries-to-avoid'] },
      ].map(({ key, route }) => (
        <a
          href={`/${lang}/${route}/`}
          class="rounded-lg border border-sand-200 dark:border-sand-700 bg-white dark:bg-sand-800 px-4 py-3 hover:border-terracotta-400 dark:hover:border-terracotta-500 transition-colors text-sm font-medium text-sand-700 dark:text-sand-200"
        >
          {t(key as any)}
        </a>
      ))}
    </div>
  </section>
  <details class="max-w-6xl mx-auto px-4 py-6">
    <summary class="cursor-pointer text-sm font-medium text-sand-600 dark:text-sand-400 hover:text-sand-800 dark:hover:text-sand-200">
      {t('home.all_countries')} ({countries.length})
    </summary>
    <div class="mt-4 columns-2 sm:columns-3 md:columns-4 gap-4">
      {countries.map(c => (
        <a href={`/${lang}/${routes[lang].country}/${c.iso3.toLowerCase()}/`}
           class="block text-sm text-sand-600 dark:text-sand-400 hover:text-terracotta-500 dark:hover:text-terracotta-400 py-0.5">
          {c.name[lang]}
        </a>
      ))}
    </div>
  </details>
</Base>
