---
export const prerender = true;
import HubPageLayout from '../../../components/hub/HubPageLayout.astro';
import { loadLatestScores, loadHistoricalScores } from '../../../lib/scores';
import { getImprovingSafety } from '../../../lib/hub-data';
import { useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

const lang: Lang = 'pt';
const t = useTranslations(lang);
const countries = loadLatestScores();
const history = loadHistoricalScores();
const ranked = getImprovingSafety(countries, history, 20);
const deltas = new Map(ranked.map(c => [c.iso3, c.delta]));
const title = t('hub.improving.title' as any);
const description = t('hub.improving.description' as any);
const intro = t('hub.improving.intro' as any);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  description,
  numberOfItems: ranked.length,
  itemListElement: ranked.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name[lang],
  })),
};
---
<HubPageLayout
  lang={lang}
  title={title}
  description={description}
  intro={intro}
  jsonLd={jsonLd}
  countries={ranked}
  showDelta={true}
  deltas={deltas}
/>
