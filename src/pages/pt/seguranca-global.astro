---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { loadLatestSnapshot, loadGlobalHistory } from '../../lib/scores';
import { buildGlobalSafetyJsonLd } from '../../lib/seo';
import { scoreToColor } from '../../lib/colors';

const lang: Lang = 'pt';
const t = useTranslations(lang);

const snapshot = loadLatestSnapshot();
const globalScore = snapshot?.globalScore ?? 0;
const bgColor = scoreToColor(globalScore);
const globalHistory = loadGlobalHistory();

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const dateModified = new Date().toISOString().split('T')[0];
const jsonLd = buildGlobalSafetyJsonLd(globalScore, canonicalUrl, lang, dateModified);

const showChart = globalHistory.length >= 2;
---

<Base lang={lang} title={t('global.page_title')} description={t('global.page_description')} jsonLd={jsonLd} ogImage="/og/default.png">
  <div class="max-w-4xl mx-auto px-4 py-8 space-y-8">
    <!-- Score Hero -->
    <section class="text-center py-8">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-6">
        {t('global.page_title')}
      </h1>
      <div
        class="inline-flex flex-col items-center justify-center rounded-2xl px-8 py-6 shadow-lg"
        style={`background-color: ${bgColor}; color: #fff;`}
      >
        <span class="text-6xl md:text-8xl font-heading font-bold leading-none">
          {globalScore.toFixed(1)}
        </span>
        <span class="text-lg md:text-xl font-medium mt-1 opacity-90">
          {t('global.out_of')}
        </span>
      </div>
      <p class="mt-4 text-lg font-medium text-sand-600 dark:text-sand-400">
        {t('global.current_score')}
      </p>
    </section>

    <!-- Trend Chart -->
    <section class="py-6">
      <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
        {t('global.trend_title')}
      </h2>

      {showChart ? (
        <div>
          <div id="global-chart-container" class="relative" data-history={JSON.stringify(globalHistory)} data-lang={lang}>
            <svg id="global-chart-svg" viewBox="0 0 800 240" class="w-full text-sand-700 dark:text-sand-300" role="img" aria-label={t('global.trend_title')}></svg>
            <div id="global-tooltip" class="absolute hidden pointer-events-none bg-sand-100 dark:bg-sand-800 border border-terracotta-300 dark:border-terracotta-600 rounded px-2 py-1 text-sm shadow-md z-10 whitespace-nowrap"></div>
          </div>
          <div class="flex flex-wrap items-center gap-2 mt-2">
            <div class="time-range-selector inline-flex bg-sand-100 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg p-0.5" role="group" aria-label="Time range">
              <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-terracotta-500 text-white" data-range="1m" type="button" aria-pressed="true">1M</button>
              <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="6m" type="button">6M</button>
              <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="1y" type="button">1Y</button>
              <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="10y" type="button">10Y</button>
              <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="max" type="button">MAX</button>
            </div>
            <button id="global-reset-btn" class="hidden px-2.5 py-1 text-xs font-medium rounded-md border border-sand-300 dark:border-sand-600 transition-colors cursor-pointer bg-sand-100 dark:bg-sand-800 text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" type="button">Reset</button>
          </div>
        </div>
      ) : (
        <p class="text-sm text-sand-500 dark:text-sand-400 italic">
          {t('global.trend_accumulating')}
        </p>
      )}
    </section>

    <!-- Methodology -->
    <section class="py-6">
      <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
        {t('global.methodology_title')}
      </h2>
      <p class="text-sand-600 dark:text-sand-400 leading-relaxed">
        {t('global.methodology_text')}
      </p>
      <p class="mt-4">
        <a href={`/${lang}/methodology/`} class="text-terracotta-500 hover:text-terracotta-600 underline">
          {t('global.methodology_link')}
        </a>
      </p>
    </section>
  </div>

  <script>
    import { scaleLinear, scaleTime, line, area, utcFormat, brushX, select, easeCubicOut } from 'd3';
    import { scoreToColor } from '../../lib/colors';

    function smartDateFormat(dates: Date[]): (d: Date) => string {
      const first = dates[0], last = dates[dates.length - 1];
      if (first.getUTCFullYear() !== last.getUTCFullYear()) {
        return utcFormat('%b %Y');
      } else if (first.getUTCMonth() !== last.getUTCMonth()) {
        return utcFormat('%b %d');
      } else {
        return utcFormat('%d');
      }
    }

    const container = document.getElementById('global-chart-container');
    if (container) {
      const svg = document.getElementById('global-chart-svg') as unknown as SVGSVGElement;
      const tooltip = document.getElementById('global-tooltip')!;
      const resetBtn = document.getElementById('global-reset-btn')!;
      const lang = container.dataset.lang || 'en';

      interface HistoryPoint { date: string; score: number; }
      const fullData: HistoryPoint[] = JSON.parse(container.dataset.history || '[]');

      if (fullData.length >= 2) {
        const width = 800;
        const height = 240;
        const margin = { top: 20, right: 20, bottom: 40, left: 50 };
        const innerWidth = width - margin.left - margin.right;
        const innerHeight = height - margin.top - margin.bottom;

        let currentData: HistoryPoint[] = fullData;
        let xScale: ReturnType<typeof scaleTime<number, number>>;
        let yScale: ReturnType<typeof scaleLinear<number, number>>;

        // Pinned tooltip state
        let pinnedPoint: HistoryPoint | null = null;

        // Precompute slopes for magnet snap
        function computeSlopes(data: HistoryPoint[]): number[] {
          const slopes: number[] = [];
          for (let i = 0; i < data.length; i++) {
            let slope = 0;
            if (i > 0) slope = Math.abs(data[i].score - data[i - 1].score);
            if (i < data.length - 1) slope = Math.max(slope, Math.abs(data[i + 1].score - data[i].score));
            slopes.push(slope);
          }
          return slopes;
        }

        let currentSlopes: number[] = computeSlopes(fullData);
        let avgSlope = currentSlopes.reduce((a, b) => a + b, 0) / currentSlopes.length;

        function computeYDomain(data: HistoryPoint[]): [number, number] {
          const scores = data.map(d => d.score);
          const min = Math.min(...scores);
          const max = Math.max(...scores);
          const range = max - min;
          const pad = Math.max(range * 0.2, 0.2);
          return [
            Math.max(1, Math.floor((min - pad) * 2) / 2),
            Math.min(10, Math.ceil((max + pad) * 2) / 2),
          ];
        }

        function findNearestWithSnap(mouseX: number, data: HistoryPoint[], slopes: number[], avg: number): HistoryPoint {
          let nearest = data[0];
          let minDist = Infinity;
          for (let i = 0; i < data.length; i++) {
            const px = xScale(new Date(data[i].date + 'T00:00:00Z'));
            const radius = slopes[i] > avg ? 2 : 1;
            const dist = Math.abs(px - mouseX) / radius;
            if (dist < minDist) { minDist = dist; nearest = data[i]; }
          }
          return nearest;
        }

        function renderChart(filteredData: HistoryPoint[], allData: HistoryPoint[]): void {
          currentData = filteredData;
          pinnedPoint = null;

          // Recompute slopes
          currentSlopes = computeSlopes(filteredData);
          avgSlope = currentSlopes.length > 0 ? currentSlopes.reduce((a, b) => a + b, 0) / currentSlopes.length : 0;

          const dates = filteredData.map(d => new Date(d.date + 'T00:00:00Z'));
          xScale = scaleTime()
            .domain([dates[0], dates[dates.length - 1]])
            .range([0, innerWidth]);

          const [yMin, yMax] = computeYDomain(filteredData);
          yScale = scaleLinear()
            .domain([yMin, yMax])
            .range([innerHeight, 0]);

          const lineGen = line<HistoryPoint>()
            .x(d => xScale(new Date(d.date + 'T00:00:00Z')))
            .y(d => yScale(d.score));

          const areaGen = area<HistoryPoint>()
            .x(d => xScale(new Date(d.date + 'T00:00:00Z')))
            .y0(innerHeight)
            .y1(d => yScale(d.score));

          const pathD = lineGen(filteredData) ?? '';
          const areaD = areaGen(filteredData) ?? '';

          const lastPoint = filteredData[filteredData.length - 1];
          const endCx = xScale(new Date(lastPoint.date + 'T00:00:00Z'));
          const endCy = yScale(lastPoint.score);
          const endColor = scoreToColor(lastPoint.score);

          const yTickCount = 5;
          const yTickStep = (yMax - yMin) / (yTickCount - 1);
          let gridLines = '';
          let yLabels = '';
          for (let i = 0; i < yTickCount; i++) {
            const val = yMin + i * yTickStep;
            const yPos = yScale(val);
            gridLines += `<line x1="0" y1="${yPos}" x2="${innerWidth}" y2="${yPos}" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.3" />`;
            yLabels += `<text x="-10" y="${yPos}" text-anchor="end" dominant-baseline="middle" class="text-xs fill-sand-500 dark:fill-sand-400" font-size="12">${val.toFixed(1)}</text>`;
          }

          const tickCount = Math.min(6, dates.length);
          const fmt = smartDateFormat(dates);
          const ticks: {x: number, label: string}[] = [];
          for (let i = 0; i < tickCount; i++) {
            const idx = Math.round((i / (tickCount - 1)) * (dates.length - 1));
            ticks.push({ x: xScale(dates[idx]), label: fmt(dates[idx]) });
          }
          const minGap = 50;
          for (let i = ticks.length - 2; i >= 0; i--) {
            if (ticks[i + 1].x - ticks[i].x < minGap) {
              ticks.splice(i, 1);
            }
          }
          let xLabels = '';
          for (let ti = 0; ti < ticks.length; ti++) {
            const t = ticks[ti];
            const anchor = ti === ticks.length - 1 ? 'end' : ti === 0 ? 'start' : 'middle';
            xLabels += `<text x="${t.x}" y="${innerHeight + 25}" text-anchor="${anchor}" class="text-xs fill-sand-500 dark:fill-sand-400" font-size="11">${t.label}</text>`;
          }

          svg.innerHTML = `
            <defs>
              <linearGradient id="globalGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#c47a5a" stop-opacity="0.3" />
                <stop offset="100%" stop-color="#c47a5a" stop-opacity="0.05" />
              </linearGradient>
              <clipPath id="global-chart-clip"><rect x="0" y="0" width="${innerWidth}" height="${innerHeight}"/></clipPath>
            </defs>
            <g class="chart-main" transform="translate(${margin.left}, ${margin.top})">
              ${gridLines}
              <path class="area-path" d="${areaD}" fill="url(#globalGradient)" clip-path="url(#global-chart-clip)" />
              <path class="line-path" d="${pathD}" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" clip-path="url(#global-chart-clip)" />
              <circle class="endpoint-circle" cx="${endCx}" cy="${endCy}" r="4" fill="${endColor}" />
              ${yLabels}
              ${xLabels}
            </g>
          `;

          attachBrush(allData);
        }

        function attachBrush(allData: HistoryPoint[]): void {
          const mainGroup = svg.querySelector('.chart-main');
          if (!mainGroup) return;

          const brush = brushX()
            .extent([[0, 0], [innerWidth, innerHeight]])
            .on('end', (event: any) => {
              if (!event.selection) return;
              const [x0, x1] = event.selection as [number, number];
              const date0 = xScale.invert(x0);
              const date1 = xScale.invert(x1);

              const filtered = allData.filter(d => {
                const dt = new Date(d.date + 'T00:00:00Z');
                return dt >= date0 && dt <= date1;
              });

              if (filtered.length < 2) return;

              const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
              const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

              renderChart(filtered, allData);
              resetBtn.classList.remove('hidden');

              animatePaths(oldLinePath, oldAreaPath);
            });

          const brushGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          brushGroup.setAttribute('class', 'brush');
          mainGroup.appendChild(brushGroup);

          select(brushGroup).call(brush);

          const style = document.createElementNS('http://www.w3.org/2000/svg', 'style');
          style.textContent = `.brush .selection { fill: #c47a5a; fill-opacity: 0.15; stroke: #c47a5a; stroke-opacity: 0.4; }`;
          svg.insertBefore(style, svg.firstChild);
        }

        function animatePaths(oldLineD: string, oldAreaD: string): void {
          const linePath = svg.querySelector('.line-path');
          const areaPath = svg.querySelector('.area-path');
          if (linePath && oldLineD) {
            const newLineD = linePath.getAttribute('d') || '';
            select(linePath).attr('d', oldLineD)
              .transition().duration(300).ease(easeCubicOut)
              .attr('d', newLineD);
          }
          if (areaPath && oldAreaD) {
            const newAreaD = areaPath.getAttribute('d') || '';
            select(areaPath).attr('d', oldAreaD)
              .transition().duration(300).ease(easeCubicOut)
              .attr('d', newAreaD);
          }
        }

        resetBtn.addEventListener('click', () => {
          const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
          const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

          renderChart(fullData, fullData);
          resetBtn.classList.add('hidden');

          animatePaths(oldLinePath, oldAreaPath);
        });

        // Crosshair elements
        const svgRect = () => svg.getBoundingClientRect();
        const viewBox = svg.viewBox.baseVal;

        function ensureCrosshairElements(): { vLine: SVGLineElement; dot: SVGCircleElement } {
          let vLine = svg.querySelector('.crosshair-line') as SVGLineElement | null;
          let dot = svg.querySelector('.crosshair-dot') as SVGCircleElement | null;
          const mainGroup = svg.querySelector('.chart-main');
          if (!mainGroup) return { vLine: vLine!, dot: dot! };
          if (!vLine) {
            vLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            vLine.setAttribute('class', 'crosshair-line');
            vLine.setAttribute('stroke', '#c47a5a');
            vLine.setAttribute('stroke-width', '1');
            vLine.setAttribute('stroke-dasharray', '3 3');
            vLine.setAttribute('opacity', '0.6');
            vLine.setAttribute('y1', '0');
            vLine.setAttribute('y2', String(innerHeight));
            vLine.style.display = 'none';
            mainGroup.appendChild(vLine);
          }
          if (!dot) {
            dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            dot.setAttribute('class', 'crosshair-dot');
            dot.setAttribute('r', '5');
            dot.setAttribute('stroke', '#fff');
            dot.setAttribute('stroke-width', '2');
            dot.style.display = 'none';
            mainGroup.appendChild(dot);
          }
          return { vLine, dot };
        }

        function showCrosshair(point: HistoryPoint): void {
          const { vLine, dot } = ensureCrosshairElements();
          if (!vLine || !dot) return;
          const cx = xScale(new Date(point.date + 'T00:00:00Z'));
          const cy = yScale(point.score);
          vLine.setAttribute('x1', String(cx));
          vLine.setAttribute('x2', String(cx));
          vLine.style.display = '';
          dot.setAttribute('cx', String(cx));
          dot.setAttribute('cy', String(cy));
          dot.setAttribute('fill', scoreToColor(point.score));
          dot.style.display = '';
        }

        function hideCrosshair(): void {
          const vLine = svg.querySelector('.crosshair-line') as SVGElement | null;
          const dot = svg.querySelector('.crosshair-dot') as SVGElement | null;
          if (vLine) vLine.style.display = 'none';
          if (dot) dot.style.display = 'none';
        }

        function removePinnedCircle(): void {
          svg.querySelector('.pinned-circle')?.remove();
        }

        function drawPinnedCircle(point: HistoryPoint): void {
          removePinnedCircle();
          const mainGroup = svg.querySelector('.chart-main');
          if (!mainGroup) return;
          const cx = xScale(new Date(point.date + 'T00:00:00Z'));
          const cy = yScale(point.score);
          const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          circle.setAttribute('class', 'pinned-circle');
          circle.setAttribute('cx', String(cx));
          circle.setAttribute('cy', String(cy));
          circle.setAttribute('r', '6');
          circle.setAttribute('fill', scoreToColor(point.score));
          circle.setAttribute('stroke', '#fff');
          circle.setAttribute('stroke-width', '2');
          mainGroup.appendChild(circle);
        }

        const localeMap: Record<string, string> = { en: 'en-US', it: 'it-IT', es: 'es-ES', fr: 'fr-FR', pt: 'pt-BR' };
        function formatPoint(point: HistoryPoint): string {
          const d = new Date(point.date + 'T00:00:00Z');
          const dateStr = d.toLocaleDateString(localeMap[lang] || 'en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          return `${dateStr}: ${point.score.toFixed(2)}`;
        }

        function positionTooltip(point: HistoryPoint, rect: DOMRect): void {
          const scaleX = rect.width / viewBox.width;
          const scaleY = rect.height / viewBox.height;
          const pointCx = xScale(new Date(point.date + 'T00:00:00Z')) + margin.left;
          const pointCy = yScale(point.score) + margin.top;
          const tooltipX = pointCx * scaleX - tooltip.offsetWidth / 2;
          const tooltipY = pointCy * scaleY - tooltip.offsetHeight - 8;
          tooltip.style.left = `${Math.max(0, Math.min(tooltipX, rect.width - tooltip.offsetWidth))}px`;
          tooltip.style.top = `${Math.max(0, tooltipY)}px`;
        }

        const showTooltip = (clientX: number, _clientY: number) => {
          if (pinnedPoint) return;
          const rect = svgRect();
          const mouseX = (clientX - rect.left) / rect.width * viewBox.width - margin.left;
          const nearest = findNearestWithSnap(mouseX, currentData, currentSlopes, avgSlope);
          tooltip.textContent = formatPoint(nearest);
          tooltip.classList.remove('hidden');
          positionTooltip(nearest, rect);
          showCrosshair(nearest);
        };

        const hideTooltip = () => {
          if (pinnedPoint) return;
          tooltip.classList.add('hidden');
          hideCrosshair();
        };

        svg.addEventListener('mousemove', (e: MouseEvent) => showTooltip(e.clientX, e.clientY));
        svg.addEventListener('mouseleave', hideTooltip);

        svg.addEventListener('click', (e: MouseEvent) => {
          const rect = svgRect();
          const mouseX = (e.clientX - rect.left) / rect.width * viewBox.width - margin.left;
          if (pinnedPoint) {
            pinnedPoint = null;
            removePinnedCircle();
            tooltip.classList.add('hidden');
            hideCrosshair();
            return;
          }
          const nearest = findNearestWithSnap(mouseX, currentData, currentSlopes, avgSlope);
          pinnedPoint = nearest;
          tooltip.textContent = formatPoint(nearest);
          tooltip.classList.remove('hidden');
          positionTooltip(nearest, rect);
          showCrosshair(nearest);
          drawPinnedCircle(nearest);
        });

        svg.addEventListener('touchstart', (e: TouchEvent) => {
          e.preventDefault();
          showTooltip(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: false });

        document.addEventListener('touchstart', (e: TouchEvent) => {
          if (!container.contains(e.target as Node)) {
            pinnedPoint = null;
            removePinnedCircle();
            hideTooltip();
          }
        });

        // Time range buttons
        let currentTimeRange = '1m';

        function filterByTimeRange(data: HistoryPoint[], range: string): HistoryPoint[] {
          if (range === 'max') return data;
          const now = new Date();
          const daysMap: Record<string, number> = { '1m': 30, '6m': 180, '1y': 365, '10y': 3650 };
          const days = daysMap[range] || 0;
          if (!days) return data;
          const cutoff = new Date(now.getTime() - days * 86400000);
          const filtered = data.filter(d => new Date(d.date + 'T00:00:00Z') >= cutoff);
          return filtered.length >= 2 ? filtered : data;
        }

        function applyTimeRange(range: string): void {
          currentTimeRange = range;
          const filtered = filterByTimeRange(fullData, range);

          const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
          const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

          renderChart(filtered, fullData);
          animatePaths(oldLinePath, oldAreaPath);
          if (range === 'max') {
            resetBtn.classList.add('hidden');
          } else {
            resetBtn.classList.remove('hidden');
          }

          document.querySelectorAll('.time-range-btn').forEach(btn => {
            const el = btn as HTMLElement;
            if (el.dataset.range === range) {
              el.className = 'time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-terracotta-500 text-white';
              el.setAttribute('aria-pressed', 'true');
            } else {
              el.className = 'time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700';
              el.setAttribute('aria-pressed', 'false');
            }
          });
        }

        document.querySelectorAll('.time-range-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            applyTimeRange((btn as HTMLElement).dataset.range || 'max');
          });
        });

        applyTimeRange('1m');
      }
    }
  </script>
</Base>
