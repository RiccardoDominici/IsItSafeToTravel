---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';
import { routes } from '../../../i18n/ui';
import { buildWebPageJsonLd, buildFaqPageJsonLd } from '../../../lib/seo';
import weightsConfig from '../../../pipeline/config/weights.json';

const lang: Lang = 'fr';
const r = routes[lang];
const t = useTranslations(lang);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const webPageJsonLd = buildWebPageJsonLd(t('methodology.title'), t('methodology.description'), canonicalUrl, lang);
const faqQuestions = weightsConfig.pillars.map(pillar => ({
  question: t(`methodology.pillar.${pillar.name}.title` as any),
  answer: t(`methodology.pillar.${pillar.name}.description` as any),
}));
const faqJsonLd = buildFaqPageJsonLd(faqQuestions);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { ...webPageJsonLd, '@context': undefined },
    { ...faqJsonLd, '@context': undefined },
  ],
};

// Data source metadata for the table
const dataSources = [
  { key: 'wb', frequency: t('methodology.frequency.annual') },
  { key: 'gpi', frequency: t('methodology.frequency.annual') },
  { key: 'inform', frequency: t('methodology.frequency.quarterly') },
  { key: 'ucdp', frequency: t('methodology.frequency.annual') },
  { key: 'us_advisory', frequency: t('methodology.frequency.varies') },
  { key: 'uk_advisory', frequency: t('methodology.frequency.varies') },
  { key: 'reliefweb', frequency: t('methodology.frequency.daily') },
  { key: 'gdacs', frequency: t('methodology.frequency.daily') },
  { key: 'gdelt', frequency: t('methodology.frequency.daily') },
  { key: 'who_dons', frequency: t('methodology.frequency.weekly') },
];

// Pillar name to i18n key mapping
const pillarI18n: Record<string, string> = {
  conflict: 'country.pillar.conflict',
  crime: 'country.pillar.crime',
  health: 'country.pillar.health',
  governance: 'country.pillar.governance',
  environment: 'country.pillar.environment',
};
---
<Base lang={lang} title={t('methodology.title')} description={t('methodology.description')} jsonLd={jsonLd}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumb lang={lang} items={[
      { label: t('nav.home'), href: `/${lang}/` },
      { label: t('nav.methodology'), href: `/${lang}/${r.methodology}/` },
    ]} />
    <h1 class="text-3xl font-heading font-bold text-sand-900 dark:text-sand-50 mb-8">{t('methodology.title')}</h1>

    <!-- Overview -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.overview_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.overview_text')}</p>
    </section>

    <!-- Data Sources Table -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.sources_title')}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-sand-300 dark:border-sand-600">
              <th class="text-left py-2 pr-4 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.source')}</th>
              <th class="text-left py-2 pr-4 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.measures')}</th>
              <th class="text-left py-2 pr-4 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.frequency')}</th>
              <th class="text-left py-2 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.link')}</th>
            </tr>
          </thead>
          <tbody>
            {dataSources.map(src => (
              <tr class="border-b border-sand-200 dark:border-sand-700">
                <td class="py-3 pr-4 font-medium text-sand-800 dark:text-sand-100">{t(`methodology.source.${src.key}` as any)}</td>
                <td class="py-3 pr-4 text-sand-600 dark:text-sand-300">{t(`methodology.source.${src.key}_desc` as any)}</td>
                <td class="py-3 pr-4 text-sand-600 dark:text-sand-300">{src.frequency}</td>
                <td class="py-3"><a href={t(`methodology.source.${src.key}_url` as any)} target="_blank" rel="noopener noreferrer" class="text-terracotta-500 hover:text-terracotta-600 dark:text-terracotta-400 underline">Visit</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Scoring Formula -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.formula_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-4">{t('methodology.formula_text')}</p>
      <div class="bg-sand-100 dark:bg-sand-800 rounded-lg p-4 font-mono text-sm text-sand-800 dark:text-sand-200">
        Score = (Baseline x 0.70 + Signal x 0.30) where each = (Conflict x 0.30 + Crime x 0.25 + Health x 0.20 + Governance x 0.15 + Environment x 0.10) x 9 + 1
      </div>
    </section>

    <!-- Baseline + Signal Architecture -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.tiered_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.tiered_text')}</p>
    </section>

    <!-- Data Freshness Decay -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.decay_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.decay_text')}</p>
    </section>

    <!-- How INFORM Enriches the Scoring -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.inform_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.inform_text')}</p>
    </section>

    <!-- Global Peace Index -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.gpi_pending_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.gpi_pending_text')}</p>
    </section>

    <!-- Category Weights Table -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.weights_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-4">{t('methodology.weights_text')}</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-sand-300 dark:border-sand-600">
              <th class="text-left py-2 pr-4 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.category')}</th>
              <th class="text-left py-2 pr-4 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.weight')}</th>
              <th class="text-left py-2 text-sand-600 dark:text-sand-400 font-medium">{t('methodology.table.indicators')}</th>
            </tr>
          </thead>
          <tbody>
            {weightsConfig.pillars.map(pillar => (
              <tr class="border-b border-sand-200 dark:border-sand-700">
                <td class="py-3 pr-4 font-medium text-sand-800 dark:text-sand-100">{t(pillarI18n[pillar.name] as any)}</td>
                <td class="py-3 pr-4 text-sand-600 dark:text-sand-300">{(pillar.weight * 100).toFixed(0)}%</td>
                <td class="py-3 text-sand-600 dark:text-sand-300">{pillar.indicators.map(ind => t(`methodology.indicator.${ind}` as any)).join(', ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Understanding Each Category -->
    <section class="mb-10">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.pillar_section_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-4">{t('methodology.pillar_section_intro')}</p>
      <div class="space-y-3">
        {weightsConfig.pillars.map(pillar => (
          <details class="border border-sand-200 dark:border-sand-700 rounded-lg">
            <summary class="px-4 py-3 cursor-pointer font-medium text-sand-800 dark:text-sand-100 hover:bg-sand-50 dark:hover:bg-sand-800 rounded-lg select-none">
              {t(`methodology.pillar.${pillar.name}.title` as any)}
            </summary>
            <div class="px-4 pb-4 pt-1 text-sm text-sand-700 dark:text-sand-300 space-y-2">
              <p>{t(`methodology.pillar.${pillar.name}.description` as any)}</p>
              <p><strong class="text-sand-800 dark:text-sand-100">{t('methodology.pillar.sources_label')}</strong> {t(`methodology.pillar.${pillar.name}.sources` as any)}</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2">
                <div class="bg-red-50 dark:bg-red-900/20 rounded p-2">
                  <span class="text-xs font-medium text-red-700 dark:text-red-400 uppercase">{t('methodology.pillar.low_label')}</span>
                  <p class="text-xs mt-1">{t(`methodology.pillar.${pillar.name}.low_score` as any)}</p>
                </div>
                <div class="bg-green-50 dark:bg-green-900/20 rounded p-2">
                  <span class="text-xs font-medium text-green-700 dark:text-green-400 uppercase">{t('methodology.pillar.high_label')}</span>
                  <p class="text-xs mt-1">{t(`methodology.pillar.${pillar.name}.high_score` as any)}</p>
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Limitations -->
    <section>
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('methodology.limitations_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('methodology.limitations_text')}</p>
    </section>
  </div>
</Base>
