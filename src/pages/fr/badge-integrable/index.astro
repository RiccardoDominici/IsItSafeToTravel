---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { loadLatestScores } from '../../../lib/scores';
import { useTranslations } from '../../../i18n/utils';
import { routes } from '../../../i18n/ui';
import type { Lang } from '../../../i18n/ui';
import { buildWebPageJsonLd } from '../../../lib/seo';

const lang: Lang = 'fr';
const t = useTranslations(lang);
const r = routes[lang];
const countries = loadLatestScores().sort((a, b) => a.name[lang].localeCompare(b.name[lang]));
const title = t('badge.title' as any);
const description = t('badge.description' as any);
const canonicalUrl = `https://isitsafetotravel.org/${lang}/${r['embed-badge']}/`;
const jsonLd = buildWebPageJsonLd(title, description, canonicalUrl, lang);
---
<Base lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <div class="max-w-4xl mx-auto px-4 py-8 space-y-8">
    <Breadcrumb lang={lang} items={[
      { label: t('nav.home'), href: `/${lang}/` },
      { label: title, href: '' },
    ]} />
    <header class="text-center space-y-4">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-sand-800 dark:text-sand-100">{title}</h1>
      <p class="text-base text-sand-600 dark:text-sand-400 max-w-2xl mx-auto">{t('badge.instructions' as any)}</p>
    </header>
    <div class="max-w-xl mx-auto space-y-6">
      <div>
        <label for="badge-country" class="block text-sm font-medium text-sand-700 dark:text-sand-300 mb-2">{t('badge.select_country' as any)}</label>
        <select id="badge-country" data-country-route={r.country} class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-sand-800 dark:text-sand-100 focus:ring-2 focus:ring-terracotta-400">
          {countries.map(c => (
            <option value={c.iso3.toLowerCase()} data-name={c.name[lang]} data-score={c.score.toFixed(1)}>{c.name[lang]} ({c.score.toFixed(1)}/10)</option>
          ))}
        </select>
      </div>
      <div>
        <h2 class="text-sm font-medium text-sand-700 dark:text-sand-300 mb-2">{t('badge.preview' as any)}</h2>
        <div class="rounded-lg border border-sand-200 dark:border-sand-700 bg-sand-50 dark:bg-sand-900 p-6 flex items-center justify-center">
          <img id="badge-preview" src={`/badge/${countries[0]?.iso3.toLowerCase()}.svg`} alt="Safety Badge" width="300" height="80" />
        </div>
      </div>
      <div>
        <h2 class="text-sm font-medium text-sand-700 dark:text-sand-300 mb-2">{t('badge.embed_html' as any)}</h2>
        <div class="relative">
          <textarea id="embed-html" readonly rows="3" class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-sand-800 dark:text-sand-100 font-mono text-xs">{`<a href="https://isitsafetotravel.org/${lang}/${r.country}/${countries[0]?.iso3.toLowerCase()}/"><img src="https://isitsafetotravel.org/badge/${countries[0]?.iso3.toLowerCase()}.svg" alt="${countries[0]?.name[lang]} Safety Score" width="300" height="80"></a>`}</textarea>
          <button data-copy="embed-html" class="absolute top-2 right-2 px-3 py-1 text-xs font-medium rounded bg-terracotta-500 text-white hover:bg-terracotta-600 transition-colors">{t('badge.copy' as any)}</button>
        </div>
      </div>
      <div>
        <h2 class="text-sm font-medium text-sand-700 dark:text-sand-300 mb-2">{t('badge.embed_markdown' as any)}</h2>
        <div class="relative">
          <textarea id="embed-markdown" readonly rows="2" class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-sand-800 dark:text-sand-100 font-mono text-xs">{`[![${countries[0]?.name[lang]} Safety Score](https://isitsafetotravel.org/badge/${countries[0]?.iso3.toLowerCase()}.svg)](https://isitsafetotravel.org/${lang}/${r.country}/${countries[0]?.iso3.toLowerCase()}/)`}</textarea>
          <button data-copy="embed-markdown" class="absolute top-2 right-2 px-3 py-1 text-xs font-medium rounded bg-terracotta-500 text-white hover:bg-terracotta-600 transition-colors">{t('badge.copy' as any)}</button>
        </div>
      </div>
    </div>
  </div>
</Base>
<script>
  const select = document.getElementById('badge-country') as HTMLSelectElement;
  const preview = document.getElementById('badge-preview') as HTMLImageElement;
  const htmlArea = document.getElementById('embed-html') as HTMLTextAreaElement;
  const mdArea = document.getElementById('embed-markdown') as HTMLTextAreaElement;
  function updateBadge() {
    const iso3 = select.value;
    const option = select.selectedOptions[0];
    const name = option?.dataset.name || '';
    const lang = document.documentElement.lang || 'en';
    const countryRoute = select.dataset.countryRoute || 'country';
    preview.src = `/badge/${iso3}.svg`;
    htmlArea.value = `<a href="https://isitsafetotravel.org/${lang}/${countryRoute}/${iso3}/"><img src="https://isitsafetotravel.org/badge/${iso3}.svg" alt="${name} Safety Score" width="300" height="80"></a>`;
    mdArea.value = `[![${name} Safety Score](https://isitsafetotravel.org/badge/${iso3}.svg)](https://isitsafetotravel.org/${lang}/${countryRoute}/${iso3}/)`;
  }
  select?.addEventListener('change', updateBadge);
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = (btn as HTMLElement).dataset.copy!;
      const textarea = document.getElementById(targetId) as HTMLTextAreaElement;
      try { await navigator.clipboard.writeText(textarea.value); const original = btn.textContent; btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = original; }, 2000); } catch { textarea.select(); }
    });
  });
</script>
