---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import SafetyMap from '../../components/SafetyMap.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { buildHomepageJsonLd } from '../../lib/seo';
import snapshot from '../../../data/scores/latest.json';

const lang: Lang = 'it';
const t = useTranslations(lang);

const scores = snapshot?.countries ?? [];

const jsonLd = buildHomepageJsonLd('https://isitsafetotravels.com', lang);
---

<Base lang={lang} jsonLd={jsonLd} ogImage="/og-homepage.png">
  <section class="flex flex-col" style="height: calc(100dvh - 4rem);">
    <div class="text-center pt-4 pb-2 px-4">
      <h1 class="font-heading text-2xl md:text-3xl font-bold text-sand-800 dark:text-sand-100">
        {t('hero.title')}
      </h1>
      <p class="text-sm md:text-base text-sand-500 dark:text-sand-400 mt-1">
        {t('map.tagline')}
      </p>
    </div>
    <div class="flex-1 min-h-0">
      <SafetyMap lang={lang} scores={scores} />
    </div>
  </section>
</Base>
