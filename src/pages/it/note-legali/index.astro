---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import { useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';
import { buildWebPageJsonLd } from '../../../lib/seo';

const lang: Lang = 'it';
const t = useTranslations(lang);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = buildWebPageJsonLd(t('legal.title'), t('legal.description'), canonicalUrl, lang);
---
<Base lang={lang} title={t('legal.title')} description={t('legal.description')} jsonLd={jsonLd}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-heading font-bold text-sand-900 dark:text-sand-50 mb-8">{t('legal.heading')}</h1>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.section1_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.section1_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.section2_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.section2_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.section3_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-3">{t('legal.section3_text')}</p>
      <ul class="list-disc list-inside space-y-1 text-sand-700 dark:text-sand-300">
        <li><a href="https://travel.state.gov/content/travel/en/traveladvisories/traveladvisories.html/" target="_blank" rel="noopener noreferrer" class="text-terracotta-500 hover:text-terracotta-600 dark:text-terracotta-400 underline">{t('legal.advisory_us')}</a></li>
        <li><a href="https://www.gov.uk/foreign-travel-advice" target="_blank" rel="noopener noreferrer" class="text-terracotta-500 hover:text-terracotta-600 dark:text-terracotta-400 underline">{t('legal.advisory_uk')}</a></li>
        <li><a href="https://www.consilium.europa.eu/en/policies/travel-advice/" target="_blank" rel="noopener noreferrer" class="text-terracotta-500 hover:text-terracotta-600 dark:text-terracotta-400 underline">{t('legal.advisory_eu')}</a></li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.section4_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.section4_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.section5_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.section5_text')}</p>
    </section>

    <hr class="border-sand-200 dark:border-sand-700 my-12" />

    <h1 class="text-3xl font-heading font-bold text-sand-900 dark:text-sand-50 mb-8">{t('legal.privacy_title')}</h1>
    <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-8">{t('legal.privacy_text')}</p>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.privacy_cookies_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.privacy_cookies_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.privacy_analytics_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.privacy_analytics_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.privacy_data_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.privacy_data_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.privacy_hosting_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.privacy_hosting_text')}</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-heading font-semibold text-sand-800 dark:text-sand-100 mb-3">{t('legal.privacy_rights_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed">{t('legal.privacy_rights_text')}</p>
    </section>

    <hr class="border-sand-200 dark:border-sand-700 my-12" />

    <section class="mb-8">
      <h2 class="text-2xl font-heading font-bold text-sand-900 dark:text-sand-50 mb-4">{t('legal.imprint_title')}</h2>
      <p class="text-sand-700 dark:text-sand-300 leading-relaxed mb-4">{t('legal.imprint_text')}</p>
      <p class="text-sand-700 dark:text-sand-300">{t('legal.imprint_name')}</p>
      <p class="text-sand-700 dark:text-sand-300">{t('legal.imprint_email')}</p>
      <p class="text-xs text-amber-600 dark:text-amber-400 mt-4 italic">{t('legal.imprint_note')}</p>
    </section>

    <p class="text-xs text-sand-400 dark:text-sand-500 mt-12">{t('legal.last_updated')}</p>
  </div>
</Base>
