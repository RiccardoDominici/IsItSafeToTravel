---
import Base from '../layouts/Base.astro';
import { ui, type Lang, languages } from '../i18n/ui';

// Detect language from URL path prefix at runtime via client-side script
// For static build, default to English
const lang: Lang = 'en';

// Prepare all translations for client-side language switching
const translations: Record<string, Record<string, string>> = {};
const supportedLangs = Object.keys(languages) as Lang[];
for (const l of supportedLangs) {
  translations[l] = {
    heading: ui[l]['error.404_heading'],
    text: ui[l]['error.404_text'],
    home: ui[l]['error.404_home'],
    search: ui[l]['error.404_search'],
    searchPlaceholder: ui[l]['search.placeholder'],
    title: ui[l]['error.404_title'],
    siteTitle: ui[l]['site.title'],
  };
}

const homeLinks: Record<string, string> = {
  en: '/en/',
  it: '/it/',
  es: '/es/',
  fr: '/fr/',
  pt: '/pt/',
};
---
<Base lang={lang} title={ui[lang]['error.404_title']}>
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-8xl font-heading font-bold text-sand-300 dark:text-sand-700 mb-4">404</p>
    <h1 id="error-heading" class="text-3xl font-heading font-bold text-sand-900 dark:text-sand-50 mb-4">
      {ui[lang]['error.404_heading']}
    </h1>
    <p id="error-text" class="text-sand-600 dark:text-sand-400 mb-8 text-lg">
      {ui[lang]['error.404_text']}
    </p>
    <a
      id="error-home-link"
      href="/en/"
      class="inline-block bg-terracotta-500 hover:bg-terracotta-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors mb-8"
    >
      {ui[lang]['error.404_home']}
    </a>
    <p id="error-search-text" class="text-sand-500 dark:text-sand-400 mb-4">
      {ui[lang]['error.404_search']}
    </p>
    <div class="max-w-md mx-auto">
      <input
        id="error-search-input"
        type="text"
        placeholder={ui[lang]['search.placeholder']}
        class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-sand-50 dark:bg-sand-800 text-sand-900 dark:text-sand-50 focus:outline-none focus:ring-2 focus:ring-terracotta-500"
      />
    </div>
  </div>

  <script is:inline define:vars={{ translations, homeLinks }}>
    (function() {
      const path = window.location.pathname;
      const langMatch = path.match(/^\/(en|it|es|fr|pt)\//);
      const detectedLang = langMatch ? langMatch[1] : 'en';

      const t = translations[detectedLang] || translations['en'];
      const homeHref = homeLinks[detectedLang] || '/en/';

      // Update document language
      document.documentElement.lang = detectedLang;

      // Update page title
      document.title = t.title + ' | ' + t.siteTitle;

      // Update visible text
      const heading = document.getElementById('error-heading');
      if (heading) heading.textContent = t.heading;

      const text = document.getElementById('error-text');
      if (text) text.textContent = t.text;

      const homeLink = document.getElementById('error-home-link');
      if (homeLink) {
        homeLink.textContent = t.home;
        homeLink.setAttribute('href', homeHref);
      }

      const searchText = document.getElementById('error-search-text');
      if (searchText) searchText.textContent = t.search;

      const searchInput = document.getElementById('error-search-input');
      if (searchInput) searchInput.setAttribute('placeholder', t.searchPlaceholder);

      // Simple search redirect on Enter
      if (searchInput) {
        searchInput.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && searchInput.value.trim()) {
            window.location.href = homeHref + '?search=' + encodeURIComponent(searchInput.value.trim());
          }
        });
      }
    })();
  </script>
</Base>
