---
export const prerender = true;
// Root URL redirect is handled server-side by Cloudflare Pages Function
// (functions/index.ts) which reads Accept-Language to serve the right language.
// This static page is a fallback only — uses JS detection for non-Cloudflare envs.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="alternate" hreflang="en" href="https://isitsafetotravel.org/en/" />
    <link rel="alternate" hreflang="it" href="https://isitsafetotravel.org/it/" />
    <link rel="alternate" hreflang="es" href="https://isitsafetotravel.org/es/" />
    <link rel="alternate" hreflang="fr" href="https://isitsafetotravel.org/fr/" />
    <link rel="alternate" hreflang="pt" href="https://isitsafetotravel.org/pt/" />
    <link rel="alternate" hreflang="x-default" href="https://isitsafetotravel.org/en/" />
    <title>Is It Safe to Travel?</title>
    <script is:inline>
      (function() {
        var lang = (navigator.language || '').toLowerCase().split('-')[0];
        var supported = { it: 1, es: 1, fr: 1, pt: 1 };
        window.location.replace('/' + (supported[lang] ? lang : 'en') + '/');
      })();
    </script>
  </head>
  <body>
    <p>Redirecting... <a href="/en/">English</a> | <a href="/it/">Italiano</a> | <a href="/es/">Español</a> | <a href="/fr/">Français</a> | <a href="/pt/">Português</a></p>
  </body>
</html>
