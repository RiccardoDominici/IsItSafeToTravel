---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { loadLatestSnapshot, loadGlobalHistory } from '../../lib/scores';
import { buildGlobalSafetyJsonLd } from '../../lib/seo';
import { scoreToColor } from '../../lib/colors';
import { scaleLinear, scaleTime, line, timeFormat, utcFormat } from 'd3';

const lang: Lang = 'es';
const t = useTranslations(lang);

const snapshot = loadLatestSnapshot();
const globalScore = snapshot?.globalScore ?? 0;
const bgColor = scoreToColor(globalScore);
const globalHistory = loadGlobalHistory();
const recentHistory = globalHistory.filter(d => {
  const date = new Date(d.date + 'T00:00:00Z');
  const ninetyDaysAgo = new Date();
  ninetyDaysAgo.setDate(ninetyDaysAgo.getDate() - 90);
  return date >= ninetyDaysAgo;
});

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = buildGlobalSafetyJsonLd(globalScore, canonicalUrl, lang);

// Build full-size trend chart SVG at build time
const chartWidth = 800;
const chartHeight = 300;
const margin = { top: 20, right: 20, bottom: 40, left: 50 };
const innerWidth = chartWidth - margin.left - margin.right;
const innerHeight = chartHeight - margin.top - margin.bottom;

let pathD = '';
let endpointCx = 0;
let endpointCy = 0;
const showChart = recentHistory.length >= 2;

// Axis tick data
let xTicks: Array<{ x: number; label: string }> = [];
let yTicks: Array<{ y: number; label: string }> = [];

// Chart data points for tooltip interactivity
let chartPoints: Array<{ date: string; score: number; x: number; y: number }> = [];

if (showChart) {
  const dates = recentHistory.map(d => new Date(d.date + 'T00:00:00Z'));
  const x = scaleTime()
    .domain([dates[0], dates[dates.length - 1]])
    .range([0, innerWidth]);

  const scores = recentHistory.map(d => d.score);
  const minScore = Math.min(...scores);
  const maxScore = Math.max(...scores);
  const range = maxScore - minScore;
  const padding = Math.max(range * 0.2, 0.2);
  const yMin = Math.max(1, Math.floor((minScore - padding) * 2) / 2);
  const yMax = Math.min(10, Math.ceil((maxScore + padding) * 2) / 2);

  const y = scaleLinear()
    .domain([yMin, yMax])
    .range([innerHeight, 0]);

  const lineGen = line<{ date: string; score: number }>()
    .x(d => x(new Date(d.date + 'T00:00:00Z')))
    .y(d => y(d.score));

  pathD = lineGen(recentHistory) ?? '';

  const lastPoint = recentHistory[recentHistory.length - 1];
  endpointCx = x(new Date(lastPoint.date + 'T00:00:00Z'));
  endpointCy = y(lastPoint.score);

  // Build chart points for tooltip
  chartPoints = recentHistory.map(d => ({
    date: d.date,
    score: d.score,
    x: x(new Date(d.date + 'T00:00:00Z')),
    y: y(d.score),
  }));

  // X axis ticks (5-7 evenly spaced dates)
  const tickCount = Math.min(6, dates.length);
  const fmt = utcFormat('%b %d, %Y');
  for (let i = 0; i < tickCount; i++) {
    const idx = Math.round((i / (tickCount - 1)) * (dates.length - 1));
    xTicks.push({ x: x(dates[idx]), label: fmt(dates[idx]) });
  }

  // Y axis ticks (dynamic based on data range)
  const yTickCount = 5;
  const yTickStep = (yMax - yMin) / (yTickCount - 1);
  yTicks = Array.from({ length: yTickCount }, (_, i) => {
    const val = yMin + i * yTickStep;
    return { y: y(val), label: val.toFixed(1) };
  });
}
---

<Base lang={lang} title={t('global.page_title')} description={t('global.page_description')} jsonLd={jsonLd}>
  <div class="max-w-4xl mx-auto px-4 py-8 space-y-8">
    <!-- Score Hero -->
    <section class="text-center py-8">
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-6">
        {t('global.page_title')}
      </h1>
      <div
        class="inline-flex flex-col items-center justify-center rounded-2xl px-8 py-6 shadow-lg"
        style={`background-color: ${bgColor}; color: #fff;`}
      >
        <span class="text-6xl md:text-8xl font-heading font-bold leading-none">
          {globalScore.toFixed(1)}
        </span>
        <span class="text-lg md:text-xl font-medium mt-1 opacity-90">
          {t('global.out_of')}
        </span>
      </div>
      <p class="mt-4 text-lg font-medium text-sand-600 dark:text-sand-400">
        {t('global.current_score')}
      </p>
    </section>

    <!-- Trend Chart -->
    <section class="py-6">
      <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
        {t('global.trend_title')}
      </h2>

      {showChart ? (
        <div class="global-chart-wrapper relative" data-points={JSON.stringify(chartPoints)} data-lang={lang} data-margin-left={margin.left} data-margin-top={margin.top} data-chart-width={chartWidth}>
          <svg
            viewBox={`0 0 ${chartWidth} ${chartHeight}`}
            class="w-full text-sand-700 dark:text-sand-300"
            role="img"
            aria-label={t('global.trend_title')}
          >
            <g transform={`translate(${margin.left}, ${margin.top})`}>
              {/* Transparent hit area for mouse events */}
              <rect x={0} y={0} width={innerWidth} height={innerHeight} fill="transparent" style="pointer-events: all; cursor: crosshair;" />
              {/* Y gridlines */}
              {yTicks.map(tick => (
                <line
                  x1={0} y1={tick.y}
                  x2={innerWidth} y2={tick.y}
                  stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.3"
                />
              ))}

              {/* Trend line */}
              <path
                d={pathD}
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linejoin="round"
                stroke-linecap="round"
              />

              {/* Endpoint dot */}
              <circle cx={endpointCx} cy={endpointCy} r="4" fill={bgColor} />

              {/* Y axis labels */}
              {yTicks.map(tick => (
                <text
                  x={-10} y={tick.y}
                  text-anchor="end"
                  dominant-baseline="middle"
                  class="text-xs fill-sand-500 dark:fill-sand-400"
                  font-size="12"
                >
                  {tick.label}
                </text>
              ))}

              {/* X axis labels */}
              {xTicks.map(tick => (
                <text
                  x={tick.x} y={innerHeight + 25}
                  text-anchor="middle"
                  class="text-xs fill-sand-500 dark:fill-sand-400"
                  font-size="11"
                >
                  {tick.label}
                </text>
              ))}
            </g>
          </svg>
          <div class="global-chart-tooltip absolute hidden pointer-events-none bg-sand-100 dark:bg-sand-800 border border-terracotta-300 dark:border-terracotta-600 rounded px-2 py-1 text-sm shadow-md z-10 whitespace-nowrap"></div>
        </div>
      ) : (
        <p class="text-sm text-sand-500 dark:text-sand-400 italic">
          {t('global.trend_accumulating')}
        </p>
      )}
    </section>

    <!-- Methodology -->
    <section class="py-6">
      <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
        {t('global.methodology_title')}
      </h2>
      <p class="text-sand-600 dark:text-sand-400 leading-relaxed">
        {t('global.methodology_text')}
      </p>
      <p class="mt-4">
        <a href={`/${lang}/methodology/`} class="text-terracotta-500 hover:text-terracotta-600 underline">
          {t('global.methodology_link')}
        </a>
      </p>
    </section>
  </div>

  <script>
    const wrapper = document.querySelector('.global-chart-wrapper') as HTMLElement | null;
    if (wrapper) {
      const points: Array<{ date: string; score: number; x: number; y: number }> = JSON.parse(wrapper.dataset.points!);
      const lang = wrapper.dataset.lang || 'en';
      const marginLeft = parseFloat(wrapper.dataset.marginLeft || '50');
      const chartWidth = parseFloat(wrapper.dataset.chartWidth || '800');
      const svg = wrapper.querySelector('svg')!;
      const tooltip = wrapper.querySelector('.global-chart-tooltip') as HTMLElement;
      const localeMap: Record<string, string> = { en: 'en-US', it: 'it-IT', es: 'es-ES' };

      function showTooltip(clientX: number): void {
        const rect = svg.getBoundingClientRect();
        const mouseX = (clientX - rect.left) / rect.width * chartWidth - marginLeft;

        let nearest = points[0];
        let minDist = Infinity;
        for (const p of points) {
          const dist = Math.abs(p.x - mouseX);
          if (dist < minDist) { minDist = dist; nearest = p; }
        }

        const d = new Date(nearest.date + 'T00:00:00Z');
        const dateStr = d.toLocaleDateString(localeMap[lang] || 'en-US', { month: 'short', day: 'numeric' });
        tooltip.textContent = `${dateStr}: ${nearest.score.toFixed(1)}`;
        tooltip.classList.remove('hidden');

        const scaleXRatio = rect.width / chartWidth;
        const tooltipX = (nearest.x + marginLeft) * scaleXRatio - tooltip.offsetWidth / 2;
        tooltip.style.left = `${Math.max(0, Math.min(tooltipX, rect.width - tooltip.offsetWidth))}px`;
        tooltip.style.top = `${-tooltip.offsetHeight - 4}px`;
      }

      svg.addEventListener('mousemove', (e: MouseEvent) => showTooltip(e.clientX));
      svg.addEventListener('mouseleave', () => tooltip.classList.add('hidden'));
      svg.addEventListener('touchstart', (e: TouchEvent) => {
        e.preventDefault();
        showTooltip(e.touches[0].clientX);
      }, { passive: false });
    }
  </script>
</Base>
