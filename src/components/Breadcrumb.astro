---
import type { Lang } from '../i18n/ui';
import { buildBreadcrumbJsonLd } from '../lib/seo';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  lang: Lang;
  items: BreadcrumbItem[];
}

const { lang, items } = Astro.props;

// Build JSON-LD items with full URLs
const siteUrl = (Astro.site?.href || 'https://isitsafetotravel.org/').replace(/\/$/, '');
const jsonLdItems = items.map((item) => ({
  name: item.label,
  url: item.href.startsWith('http') ? item.href : `${siteUrl}${item.href}`,
}));
const breadcrumbJsonLd = buildBreadcrumbJsonLd(jsonLdItems);
---

<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-sand-500 dark:text-sand-400">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && (
          <span class="text-sand-400 dark:text-sand-500" aria-hidden="true">&rsaquo;</span>
        )}
        {index === items.length - 1 ? (
          <span class="text-sand-700 dark:text-sand-300 font-medium" aria-current="page">
            {item.label}
          </span>
        ) : (
          <a
            href={item.href}
            class="hover:text-terracotta-500 dark:hover:text-terracotta-400 transition-colors"
          >
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
