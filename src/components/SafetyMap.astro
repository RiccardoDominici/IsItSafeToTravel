---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { routes } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const translations = {
  nodata: t('map.tooltip.nodata'),
  zoomIn: t('map.zoom.in'),
  zoomOut: t('map.zoom.out'),
  ctrlZoom: t('map.ctrl_zoom'),
  twoFinger: t('map.two_finger'),
  sourcesLabel: t('filter.sources'),
  allSourcesLabel: t('filter.all_sources'),
};

const ADVISORY_KEYS = ['us','uk','ca','au','de','nl','jp','sk','fr','nz','ie','fi','hk','br','at','ph','be','dk','sg','ro','rs','ee','hr','ar','it','es','kr','tw','cn','in','ch','se','no','pl','cz','hu','pt'] as const;
const sourceLabels: Record<string, string> = {};
for (const key of ADVISORY_KEYS) {
  sourceLabels[key] = t(`country.advisory.${key}` as any);
}

const pillarFilters = [
  { id: 'overall', label: t('filter.overall'), weight: null as number | null },
  { id: 'conflict', label: t('country.pillar.conflict'), weight: 25 },
  { id: 'crime', label: t('country.pillar.crime'), weight: 20 },
  { id: 'health', label: t('country.pillar.health'), weight: 20 },
  { id: 'governance', label: t('country.pillar.governance'), weight: 20 },
  { id: 'environment', label: t('country.pillar.environment'), weight: 15 },
];

const zoomInLabel = t('map.zoom.in');
const zoomOutLabel = t('map.zoom.out');
const legendSafe = t('map.legend.safe');
const legendDanger = t('map.legend.danger');
const countryRoute = routes[lang].country;
---

<div
  id="safety-map-container"
  class="relative w-full h-full overflow-hidden"
  role="img"
  aria-label="Interactive world map showing safety scores by country"
  data-lang={lang}
  data-translations={JSON.stringify(translations)}
  data-source-labels={JSON.stringify(sourceLabels)}
  data-country-route={countryRoute}
>
  <!-- SVG injected by D3 -->

  <!-- Zoom guard overlay -->
  <div
    id="map-zoom-guard"
    class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300"
  >
    <div class="bg-sand-900/70 dark:bg-sand-50/70 text-sand-50 dark:text-sand-900 text-sm font-medium px-4 py-2 rounded-lg backdrop-blur-sm">
    </div>
  </div>

  <!-- Tooltip -->
  <div
    id="map-tooltip"
    class="absolute hidden pointer-events-none z-10
      bg-sand-50 dark:bg-sand-800 text-sand-900 dark:text-sand-50
      border border-sand-300 dark:border-sand-600
      rounded-lg shadow-lg px-3 py-2 text-sm font-sans"
    role="tooltip"
  >
  </div>

  <!-- Zoom controls -->
  <div class="absolute bottom-4 right-4 flex flex-col gap-1 z-10">
    <button
      id="zoom-in"
      class="w-10 h-10 bg-sand-50 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg shadow text-xl font-bold text-sand-700 dark:text-sand-200 hover:bg-sand-100 dark:hover:bg-sand-700 flex items-center justify-center cursor-pointer"
      aria-label={zoomInLabel}
    >+</button>
    <button
      id="zoom-out"
      class="w-10 h-10 bg-sand-50 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg shadow text-xl font-bold text-sand-700 dark:text-sand-200 hover:bg-sand-100 dark:hover:bg-sand-700 flex items-center justify-center cursor-pointer"
      aria-label={zoomOutLabel}
    >-</button>
  </div>

  <!-- Pillar Filter - floating top-left overlay -->
  <div class="absolute top-3 left-3 z-10" id="pillar-filter-wrapper">
    <button
      id="pillar-filter-toggle"
      class="flex items-center gap-1.5 px-3 py-2 bg-sand-50/90 dark:bg-sand-800/90 backdrop-blur-sm border border-sand-300 dark:border-sand-600 rounded-lg shadow-md text-sm font-medium text-sand-700 dark:text-sand-200 hover:bg-sand-100 dark:hover:bg-sand-700 cursor-pointer transition-colors"
      type="button"
    >
      <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 4h14M5 8h10M7 12h6M9 16h2" stroke-linecap="round" />
      </svg>
      <span id="pillar-filter-label">Filtri</span>
      <svg class="w-3 h-3 opacity-50" viewBox="0 0 12 12" fill="currentColor">
        <path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <div id="pillar-filter-dropdown" class="hidden absolute top-full left-0 mt-1 p-2 bg-sand-50/95 dark:bg-sand-800/95 backdrop-blur-sm border border-sand-300 dark:border-sand-600 rounded-lg shadow-lg min-w-[200px]">
      <div class="flex flex-col gap-0.5" id="pillar-filter-bar">
        {pillarFilters.map(f => (
          <button
            class={`pillar-pill px-3 py-1.5 text-xs font-medium rounded-md border transition-colors cursor-pointer text-left ${f.id === 'overall' ? 'bg-terracotta-500 text-white border-terracotta-500' : 'bg-transparent text-sand-600 dark:text-sand-300 border-transparent hover:bg-sand-200 dark:hover:bg-sand-700'}`}
            data-pillar={f.id}
            data-weight={f.weight}
          >
            {f.weight !== null ? f.label : t('filter.overall')}
          </button>
        ))}
      </div>
      <div class="border-t border-sand-200 dark:border-sand-700 my-2"></div>
      <div class="text-[10px] font-medium text-sand-500 dark:text-sand-400 px-1 mb-1" id="source-filter-header">
        {t('filter.sources')}
      </div>
      <div class="flex flex-col gap-0 max-h-[200px] overflow-y-auto" id="source-filter-list">
        <!-- Populated dynamically from scores.json -->
      </div>
    </div>
  </div>

  <!-- Legend -->
  <div class="absolute bottom-4 left-4 flex items-center gap-2 z-10 bg-sand-50/90 dark:bg-sand-800/90 backdrop-blur-sm rounded-lg px-3 py-2 text-xs text-sand-600 dark:text-sand-300 border border-sand-200 dark:border-sand-700">
    <span>{legendDanger}</span>
    <div class="w-24 h-3 rounded" style="background: linear-gradient(to right, #9e3a2a, #d4b83c, #4a7fbf);"></div>
    <span>{legendSafe}</span>
  </div>
</div>

<script>
  import * as d3 from 'd3';
  import * as topojson from 'topojson-client';
  import {
    safetyColorScale,
    UNSCORED_COLOR,
    UNSCORED_COLOR_DARK,
    ISO_NUMERIC_TO_ALPHA3,
  } from '../lib/map-utils';

  interface ScoreEntry {
    iso3: string;
    name: string;
    score: number;
  }

  interface Translations {
    nodata: string;
    zoomIn: string;
    zoomOut: string;
    ctrlZoom: string;
    twoFinger: string;
    sourcesLabel: string;
    allSourcesLabel: string;
  }

  async function initMap() {
    const container = document.getElementById('safety-map-container');
    if (!container) return;

    const lang = container.dataset.lang || 'en';
    const translations: Translations = JSON.parse(
      container.dataset.translations || '{}'
    );
    const countryRoute = container.dataset.countryRoute || 'country';

    // Fetch scores from static JSON file
    let scores: ScoreEntry[] = [];
    const pillarScoreMap = new Map<string, Map<string, number>>();
    const pillarLabelMap = new Map<string, string>();
    const sourceCounts = new Map<string, number>();
    const advisoryMap = new Map<string, Record<string, any>>();
    try {
      const res = await fetch('/scores.json');
      if (res.ok) {
        const snapshot = await res.json();
        scores = (snapshot.countries || []).map((c: any) => ({
          iso3: c.iso3,
          name: c.name?.[lang] || c.name?.en || c.iso3,
          score: c.score,
        }));
        // Build per-pillar score lookup
        for (const c of snapshot.countries || []) {
          const pillarMap = new Map<string, number>();
          for (const p of c.pillars || []) {
            pillarMap.set(p.name, p.score);
          }
          pillarScoreMap.set(c.iso3, pillarMap);
          // Collect advisory data
          if (c.advisories) {
            advisoryMap.set(c.iso3, c.advisories);
            for (const key of Object.keys(c.advisories)) {
              sourceCounts.set(key, (sourceCounts.get(key) || 0) + 1);
            }
          }
        }
      }
    } catch (e) {
      console.error('Failed to load scores:', e);
    }

    // Sort sources by coverage count descending
    const sortedSources = [...sourceCounts.entries()].sort((a, b) => b[1] - a[1]);
    const sourceLabelsData: Record<string, string> = JSON.parse(container.dataset.sourceLabels || '{}');
    const enabledSources = new Set<string>(sortedSources.map(s => s[0]));

    // Build source filter checkboxes
    const sourceFilterList = document.getElementById('source-filter-list');
    const sourceFilterHeader = document.getElementById('source-filter-header');

    if (sourceFilterList && sortedSources.length > 0) {
      // Update header with count
      if (sourceFilterHeader) {
        sourceFilterHeader.textContent = `${translations.sourcesLabel} (${sortedSources.length})`;
      }

      // "All sources" toggle
      const allLabel = document.createElement('label');
      allLabel.className = 'flex items-center gap-2 px-2 py-1 text-xs rounded-md hover:bg-sand-200 dark:hover:bg-sand-700 cursor-pointer font-medium';
      allLabel.innerHTML = `<input type="checkbox" checked class="accent-terracotta-500 w-3 h-3" id="source-all-toggle" /><span class="text-sand-600 dark:text-sand-300">${translations.allSourcesLabel}</span>`;
      sourceFilterList.appendChild(allLabel);

      // Individual source checkboxes
      for (const [key, count] of sortedSources) {
        const label = document.createElement('label');
        label.className = 'flex items-center gap-2 px-2 py-0.5 text-xs rounded-md hover:bg-sand-200 dark:hover:bg-sand-700 cursor-pointer';
        label.innerHTML = `<input type="checkbox" checked class="accent-terracotta-500 w-3 h-3 source-checkbox" data-source="${key}" /><span class="text-sand-600 dark:text-sand-300 truncate">${sourceLabelsData[key] || key.toUpperCase()}</span><span class="ml-auto text-[10px] text-sand-400 shrink-0">(${count})</span>`;
        sourceFilterList.appendChild(label);
      }

      // Prevent dropdown close on checkbox clicks
      sourceFilterList.addEventListener('click', (e) => {
        e.stopPropagation();
      });

      // "All sources" toggle handler
      const allToggle = document.getElementById('source-all-toggle') as HTMLInputElement | null;
      allToggle?.addEventListener('change', () => {
        const checked = allToggle.checked;
        document.querySelectorAll('.source-checkbox').forEach((cb) => {
          const input = cb as HTMLInputElement;
          input.checked = checked;
          const src = input.dataset.source;
          if (src) {
            if (checked) enabledSources.add(src);
            else enabledSources.delete(src);
          }
        });
        applySourceFilterToMap();
      });

      // Individual checkbox handlers
      sourceFilterList.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        if (!target.classList.contains('source-checkbox')) return;
        const src = target.dataset.source;
        if (!src) return;
        if (target.checked) enabledSources.add(src);
        else enabledSources.delete(src);

        // Update "All" toggle state
        const allCbs = document.querySelectorAll('.source-checkbox') as NodeListOf<HTMLInputElement>;
        const checkedCount = [...allCbs].filter(cb => cb.checked).length;
        if (allToggle) {
          allToggle.checked = checkedCount === allCbs.length;
          allToggle.indeterminate = checkedCount > 0 && checkedCount < allCbs.length;
        }
        applySourceFilterToMap();
      });
    }

    // Build pillar label map from pill buttons
    document.querySelectorAll('.pillar-pill').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.pillar;
      if (id && id !== 'overall') {
        pillarLabelMap.set(id, el.textContent?.replace(/\s*\(\d+%\)/, '').trim() || id);
      }
    });

    // Track active pillar filter (null = overall/composite)
    let currentPillar: string | null = null;

    // Build lookup maps
    const scoreMap = new Map<string, number>();
    const nameMap = new Map<string, string>();
    for (const s of scores) {
      scoreMap.set(s.iso3, s.score);
      nameMap.set(s.iso3, s.name);
    }

    // Detect dark mode
    const isDark = () => document.documentElement.classList.contains('dark');

    // Stroke colors
    const strokeColor = () => (isDark() ? '#374151' : '#e5e7eb');

    // Container dimensions
    const rect = container.getBoundingClientRect();
    const width = rect.width;
    const height = rect.height;

    // Create SVG
    const svg = d3
      .select(container)
      .insert('svg', ':first-child')
      .attr('width', '100%')
      .attr('height', '100%')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .style('display', 'block')
      .style('position', 'relative')
      .style('z-index', '0');

    const g = svg.append('g');

    // Projection
    const projection = d3
      .geoNaturalEarth1()
      .fitSize([width, height], { type: 'Sphere' } as d3.GeoPermissibleObjects);

    const path = d3.geoPath().projection(projection);

    // Zoom guard overlay
    const zoomGuard = document.getElementById('map-zoom-guard')!;
    const zoomGuardText = zoomGuard.querySelector('div')!;
    let guardTimer: ReturnType<typeof setTimeout> | null = null;

    function showZoomGuard(message: string) {
      zoomGuardText.textContent = message;
      zoomGuard.classList.remove('opacity-0');
      zoomGuard.classList.add('opacity-100');
      if (guardTimer) clearTimeout(guardTimer);
      guardTimer = setTimeout(() => {
        zoomGuard.classList.remove('opacity-100');
        zoomGuard.classList.add('opacity-0');
      }, 1500);
    }

    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    const maxZoom = isTouchDevice ? 20 : 8;

    // Zoom behavior
    const zoom = d3
      .zoom<SVGSVGElement, unknown>()
      .scaleExtent([1, maxZoom])
      .translateExtent([
        [0, 0],
        [width, height],
      ])
      .filter((event: any) => {
        // Always allow programmatic zoom (buttons)
        if (!event.type) return true;
        // Disable double-click zoom
        if (event.type === 'dblclick') return false;

        // Wheel: require Ctrl/Meta key
        if (event.type === 'wheel') {
          if (event.ctrlKey || event.metaKey) return true;
          showZoomGuard(translations.ctrlZoom);
          return false;
        }

        // Touch: require two fingers for pan/zoom
        if (event.type === 'touchstart' || event.type === 'touchmove') {
          if (event.touches && event.touches.length >= 2) return true;
          // Single finger: block entirely so browser handles native scroll
          return false;
        }

        // Allow mouse drag for panning when zoomed in (desktop only)
        if (event.type === 'mousedown' && !isTouchDevice) return true;

        return true;
      })
      .on('zoom', (event: d3.D3ZoomEvent<SVGSVGElement, unknown>) => {
        g.attr('transform', event.transform.toString());
        // On mobile, keep stroke-width visually constant regardless of zoom level
        if (isTouchDevice) {
          g.selectAll<SVGPathElement, any>('.country-path')
            .attr('stroke-width', 0.5 / event.transform.k);
        }
      });

    svg.call(zoom);

    // On touch devices: let the browser handle single-finger scroll natively,
    // but allow two-finger pinch-zoom to be captured by D3.
    // 'pan-y pinch-zoom' tells the browser: "you handle vertical scroll,
    // but don't handle pinch — let JS (D3) do it."
    if (isTouchDevice) {
      svg.style('touch-action', 'pan-y');
      // Show two-finger hint on single-finger drag attempts
      const svgEl = svg.node()!;
      let touchMoveCount = 0;
      svgEl.addEventListener('touchstart', (e: TouchEvent) => {
        touchMoveCount = 0;
      }, { passive: true });
      svgEl.addEventListener('touchmove', (e: TouchEvent) => {
        if (e.touches.length === 1) {
          touchMoveCount++;
          // Show hint after a few move events (distinguish drag from scroll)
          if (touchMoveCount === 3) {
            showZoomGuard(translations.twoFinger);
          }
        }
      }, { passive: true });
    }

    // Zoom buttons
    const zoomInBtn = document.getElementById('zoom-in');
    const zoomOutBtn = document.getElementById('zoom-out');
    if (zoomInBtn) {
      zoomInBtn.addEventListener('click', () => {
        svg.transition().duration(300).call(zoom.scaleBy, 1.5);
      });
    }
    if (zoomOutBtn) {
      zoomOutBtn.addEventListener('click', () => {
        svg.transition().duration(300).call(zoom.scaleBy, 1 / 1.5);
      });
    }

    // Tooltip
    const tooltip = document.getElementById('map-tooltip')!;

    function getDisplayScore(iso3: string): { value: number; label: string } | null {
      if (currentPillar) {
        const pillarScore = pillarScoreMap.get(iso3)?.get(currentPillar);
        if (pillarScore === undefined) return null;
        const scaled = pillarScore * 9 + 1;
        const label = pillarLabelMap.get(currentPillar) || currentPillar;
        return { value: scaled, label };
      }
      const score = scoreMap.get(iso3);
      if (score === undefined) return null;
      return { value: score, label: '' };
    }

    function showTooltip(
      event: MouseEvent | TouchEvent,
      iso3: string
    ) {
      const name = nameMap.get(iso3);
      const displayScore = getDisplayScore(iso3);
      if (!name && !displayScore) {
        tooltip.classList.add('hidden');
        return;
      }

      const displayName = name || iso3;
      const scoreHtml = displayScore
        ? displayScore.label
          ? `<div class="font-medium">${displayName}</div><div>${displayScore.value.toFixed(1)} (${displayScore.label})</div>`
          : `<div class="font-medium">${displayName}</div><div>${displayScore.value.toFixed(1)}</div>`
        : `<div class="font-medium">${displayName}</div><div>${translations.nodata}</div>`;

      // Build advisory lines
      let advisoryHtml = '';
      const advisories = advisoryMap.get(iso3);
      if (advisories) {
        const visibleAdvisories = Object.entries(advisories)
          .filter(([key]) => enabledSources.has(key))
          .sort((a, b) => (a[1] as any).level - (b[1] as any).level);
        if (visibleAdvisories.length > 0) {
          const lines = visibleAdvisories.slice(0, 4).map(([key, adv]: [string, any]) => {
            const sName = sourceLabelsData[key] || key.toUpperCase();
            return `<div>${sName}: L${adv.level}</div>`;
          });
          if (visibleAdvisories.length > 4) {
            lines.push(`<div>+${visibleAdvisories.length - 4} more</div>`);
          }
          advisoryHtml = `<div class="text-[10px] text-sand-500 dark:text-sand-400 mt-1 border-t border-sand-200 dark:border-sand-700 pt-1">${lines.join('')}</div>`;
        }
      }

      tooltip.innerHTML = scoreHtml + advisoryHtml;
      tooltip.classList.remove('hidden');

      // Position tooltip
      const containerRect = container!.getBoundingClientRect();
      let clientX: number, clientY: number;
      if ('touches' in event && event.touches.length > 0) {
        clientX = event.touches[0].clientX;
        clientY = event.touches[0].clientY;
      } else if ('clientX' in event) {
        clientX = event.clientX;
        clientY = event.clientY;
      } else {
        return;
      }

      let left = clientX - containerRect.left + 10;
      let top = clientY - containerRect.top + 10;

      // Keep tooltip within container bounds
      const ttRect = tooltip.getBoundingClientRect();
      if (left + ttRect.width > containerRect.width) {
        left = clientX - containerRect.left - ttRect.width - 10;
      }
      if (top + ttRect.height > containerRect.height) {
        top = clientY - containerRect.top - ttRect.height - 10;
      }

      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
    }

    function hideTooltip() {
      tooltip.classList.add('hidden');
    }

    // Touch tracking for mobile
    let lastTappedIso3: string | null = null;

    // Navigation helper
    function navigateToCountry(iso3: string) {
      if (!scoreMap.has(iso3)) return;
      window.location.href = `/${lang}/${countryRoute}/${iso3.toLowerCase()}`;
    }

    // Load topojson and render
    fetch('/world-topo.json')
      .then((res) => res.json())
      .then((topoData) => {
        const countries = topojson.feature(
          topoData as any,
          (topoData as any).objects.countries
        ) as any;

        g.selectAll('path')
          .data(countries.features)
          .enter()
          .append('path')
          .attr('d', path as any)
          .attr('class', 'country-path')
          .attr('fill', (d: any) => {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return isDark() ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;
            return scoreMap.has(iso3)
              ? safetyColorScale(scoreMap.get(iso3)!)
              : isDark()
                ? UNSCORED_COLOR_DARK
                : UNSCORED_COLOR;
          })
          .attr('stroke', strokeColor())
          .attr('stroke-width', 0.5)
          .style('cursor', (d: any) => {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            return iso3 && scoreMap.has(iso3) ? 'pointer' : 'default';
          })
          .on('mouseenter', function (event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            d3.select(this).attr('stroke-width', 1.5);
            showTooltip(event, iso3);
          })
          .on('mousemove', function (event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            showTooltip(event, iso3);
          })
          .on('mouseleave', function () {
            d3.select(this).attr('stroke-width', 0.5);
            hideTooltip();
          })
          .on('click', function (_event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            navigateToCountry(iso3);
          })
          .on('touchstart', function (event: TouchEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;

            if (iso3 === lastTappedIso3) {
              // Second tap: navigate
              navigateToCountry(iso3);
            } else {
              // First tap: show tooltip
              lastTappedIso3 = iso3;
              showTooltip(event, iso3);
            }
          });

        // Tap on empty area dismisses tooltip
        svg.on('click', (event: MouseEvent) => {
          if ((event.target as Element).tagName === 'svg') {
            lastTappedIso3 = null;
            hideTooltip();
          }
        });

        // Recolor map based on active pillar filter
        function recolorMap(pillarName: string | null) {
          const dark = isDark();
          g.selectAll<SVGPathElement, any>('.country-path')
            .transition()
            .duration(200)
            .attr('fill', (d: any) => {
              const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
              if (!iso3) return dark ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;

              if (pillarName) {
                const pillarScore = pillarScoreMap.get(iso3)?.get(pillarName);
                if (pillarScore === undefined) return dark ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;
                // Convert 0-1 pillar score to 1-10 scale
                return safetyColorScale(pillarScore * 9 + 1);
              }

              return scoreMap.has(iso3)
                ? safetyColorScale(scoreMap.get(iso3)!)
                : dark
                  ? UNSCORED_COLOR_DARK
                  : UNSCORED_COLOR;
            });
        }

        // Apply source filter to map: dim countries that lose all visible advisory sources
        function applySourceFilterToMap() {
          const allEnabled = enabledSources.size === sortedSources.length;
          g.selectAll<SVGPathElement, any>('.country-path')
            .transition()
            .duration(200)
            .style('opacity', (d: any) => {
              if (allEnabled) return 1;
              const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
              if (!iso3) return 1;
              const advisories = advisoryMap.get(iso3);
              if (!advisories) return 1;
              const hasVisible = Object.keys(advisories).some(k => enabledSources.has(k));
              return hasVisible ? 1 : 0.3;
            });
        }

        // Filter dropdown toggle
        const filterToggle = document.getElementById('pillar-filter-toggle');
        const filterDropdown = document.getElementById('pillar-filter-dropdown');

        filterToggle?.addEventListener('click', () => {
          filterDropdown?.classList.toggle('hidden');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
          const wrapper = document.getElementById('pillar-filter-wrapper');
          if (wrapper && !wrapper.contains(e.target as Node)) {
            filterDropdown?.classList.add('hidden');
          }
        });

        // Pill click handlers
        const activePillClasses = ['bg-terracotta-500', 'text-white', 'border-terracotta-500'];
        const inactivePillClasses = ['bg-transparent', 'text-sand-600', 'dark:text-sand-300', 'border-transparent'];

        document.querySelectorAll('.pillar-pill').forEach((btn) => {
          btn.addEventListener('click', () => {
            const el = btn as HTMLButtonElement;
            const pillarId = el.dataset.pillar || 'overall';
            currentPillar = pillarId === 'overall' ? null : pillarId;

            // Update pill styling
            document.querySelectorAll('.pillar-pill').forEach((pill) => {
              const isActive = (pill as HTMLButtonElement).dataset.pillar === pillarId;
              activePillClasses.forEach(c => pill.classList.toggle(c, isActive));
              inactivePillClasses.forEach(c => pill.classList.toggle(c, !isActive));
              if (isActive) {
                pill.classList.remove('hover:bg-sand-200', 'dark:hover:bg-sand-700');
              } else {
                pill.classList.add('hover:bg-sand-200', 'dark:hover:bg-sand-700');
              }
            });

            recolorMap(currentPillar);

            // Close dropdown after selection
            filterDropdown?.classList.add('hidden');
          });
        });

        // Dark mode observer
        const observer = new MutationObserver(() => {
          recolorMap(currentPillar);
          g.selectAll<SVGPathElement, any>('.country-path')
            .attr('stroke', strokeColor());
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['class'],
        });

        // Responsive resize
        let resizeTimer: ReturnType<typeof setTimeout>;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
            const newRect = container!.getBoundingClientRect();
            const newWidth = newRect.width;
            const newHeight = newRect.height;

            svg.attr('viewBox', `0 0 ${newWidth} ${newHeight}`);
            projection.fitSize([newWidth, newHeight], {
              type: 'Sphere',
            } as d3.GeoPermissibleObjects);

            g.selectAll<SVGPathElement, any>('.country-path').attr(
              'd',
              path as any
            );

            // Reset zoom
            svg.call(zoom.transform, d3.zoomIdentity);
          }, 250);
        });
      })
      .catch((err) => {
        console.error('Failed to load map data:', err);
      });
  }

  // Init on load and after Astro view transitions
  initMap();
  document.addEventListener('astro:after-swap', initMap);
</script>
