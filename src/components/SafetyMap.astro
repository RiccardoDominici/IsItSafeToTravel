---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { routes } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const translations = {
  nodata: t('map.tooltip.nodata'),
  zoomIn: t('map.zoom.in'),
  zoomOut: t('map.zoom.out'),
};

const pillarFilters = [
  { id: 'overall', label: t('filter.overall'), weight: null as number | null },
  { id: 'conflict', label: t('country.pillar.conflict'), weight: 25 },
  { id: 'crime', label: t('country.pillar.crime'), weight: 20 },
  { id: 'health', label: t('country.pillar.health'), weight: 20 },
  { id: 'governance', label: t('country.pillar.governance'), weight: 20 },
  { id: 'environment', label: t('country.pillar.environment'), weight: 15 },
];

const zoomInLabel = t('map.zoom.in');
const zoomOutLabel = t('map.zoom.out');
const legendSafe = t('map.legend.safe');
const legendDanger = t('map.legend.danger');
const countryRoute = routes[lang].country;
---

<div id="pillar-filter-bar" class="flex flex-wrap gap-2 mb-3 px-1">
  {pillarFilters.map(f => (
    <button
      class={`pillar-pill px-3 py-1.5 text-sm font-medium rounded-full border transition-colors cursor-pointer ${f.id === 'overall' ? 'bg-terracotta-500 text-white border-terracotta-500' : 'bg-sand-100 dark:bg-sand-800 text-sand-600 dark:text-sand-300 border-sand-300 dark:border-sand-600 hover:bg-sand-200 dark:hover:bg-sand-700'}`}
      data-pillar={f.id}
      data-weight={f.weight}
    >
      {f.weight !== null ? `${f.label} (${f.weight}%)` : f.label}
    </button>
  ))}
</div>

<div
  id="safety-map-container"
  class="relative w-full"
  style="height: calc(100dvh - 8rem);"
  data-lang={lang}
  data-translations={JSON.stringify(translations)}
  data-country-route={countryRoute}
>
  <!-- SVG injected by D3 -->

  <!-- Tooltip -->
  <div
    id="map-tooltip"
    class="absolute hidden pointer-events-none z-10
      bg-sand-50 dark:bg-sand-800 text-sand-900 dark:text-sand-50
      border border-sand-300 dark:border-sand-600
      rounded-lg shadow-lg px-3 py-2 text-sm font-sans"
    role="tooltip"
  >
  </div>

  <!-- Zoom controls -->
  <div class="absolute bottom-4 right-4 flex flex-col gap-1 z-10">
    <button
      id="zoom-in"
      class="w-10 h-10 bg-sand-50 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg shadow text-xl font-bold text-sand-700 dark:text-sand-200 hover:bg-sand-100 dark:hover:bg-sand-700 flex items-center justify-center cursor-pointer"
      aria-label={zoomInLabel}
    >+</button>
    <button
      id="zoom-out"
      class="w-10 h-10 bg-sand-50 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg shadow text-xl font-bold text-sand-700 dark:text-sand-200 hover:bg-sand-100 dark:hover:bg-sand-700 flex items-center justify-center cursor-pointer"
      aria-label={zoomOutLabel}
    >-</button>
  </div>

  <!-- Legend -->
  <div class="absolute bottom-4 left-4 flex items-center gap-2 z-10 bg-sand-50/80 dark:bg-sand-800/80 backdrop-blur-sm rounded-lg px-3 py-2 text-xs text-sand-600 dark:text-sand-300 border border-sand-200 dark:border-sand-700">
    <span>{legendDanger}</span>
    <div class="w-24 h-3 rounded" style="background: linear-gradient(to right, #9e3a2a, #d4b83c, #4a7fbf);"></div>
    <span>{legendSafe}</span>
  </div>
</div>

<script>
  import * as d3 from 'd3';
  import * as topojson from 'topojson-client';
  import {
    safetyColorScale,
    UNSCORED_COLOR,
    UNSCORED_COLOR_DARK,
    ISO_NUMERIC_TO_ALPHA3,
  } from '../lib/map-utils';

  interface ScoreEntry {
    iso3: string;
    name: string;
    score: number;
  }

  interface Translations {
    nodata: string;
    zoomIn: string;
    zoomOut: string;
  }

  async function initMap() {
    const container = document.getElementById('safety-map-container');
    if (!container) return;

    const lang = container.dataset.lang || 'en';
    const translations: Translations = JSON.parse(
      container.dataset.translations || '{}'
    );
    const countryRoute = container.dataset.countryRoute || 'country';

    // Fetch scores from static JSON file
    let scores: ScoreEntry[] = [];
    const pillarScoreMap = new Map<string, Map<string, number>>();
    const pillarLabelMap = new Map<string, string>();
    try {
      const res = await fetch('/scores.json');
      if (res.ok) {
        const snapshot = await res.json();
        scores = (snapshot.countries || []).map((c: any) => ({
          iso3: c.iso3,
          name: c.name?.[lang] || c.name?.en || c.iso3,
          score: c.score,
        }));
        // Build per-pillar score lookup
        for (const c of snapshot.countries || []) {
          const pillarMap = new Map<string, number>();
          for (const p of c.pillars || []) {
            pillarMap.set(p.name, p.score);
          }
          pillarScoreMap.set(c.iso3, pillarMap);
        }
      }
    } catch (e) {
      console.error('Failed to load scores:', e);
    }

    // Build pillar label map from pill buttons
    document.querySelectorAll('.pillar-pill').forEach((btn) => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.pillar;
      if (id && id !== 'overall') {
        pillarLabelMap.set(id, el.textContent?.replace(/\s*\(\d+%\)/, '').trim() || id);
      }
    });

    // Track active pillar filter (null = overall/composite)
    let currentPillar: string | null = null;

    // Build lookup maps
    const scoreMap = new Map<string, number>();
    const nameMap = new Map<string, string>();
    for (const s of scores) {
      scoreMap.set(s.iso3, s.score);
      nameMap.set(s.iso3, s.name);
    }

    // Detect dark mode
    const isDark = () => document.documentElement.classList.contains('dark');

    // Stroke colors
    const strokeColor = () => (isDark() ? '#374151' : '#e5e7eb');

    // Container dimensions
    const rect = container.getBoundingClientRect();
    const width = rect.width;
    const height = rect.height;

    // Create SVG
    const svg = d3
      .select(container)
      .insert('svg', ':first-child')
      .attr('width', '100%')
      .attr('height', '100%')
      .attr('viewBox', `0 0 ${width} ${height}`)
      .style('display', 'block');

    const g = svg.append('g');

    // Projection
    const projection = d3
      .geoNaturalEarth1()
      .fitSize([width, height], { type: 'Sphere' } as d3.GeoPermissibleObjects);

    const path = d3.geoPath().projection(projection);

    // Zoom behavior
    const zoom = d3
      .zoom<SVGSVGElement, unknown>()
      .scaleExtent([1, 8])
      .translateExtent([
        [0, 0],
        [width, height],
      ])
      .on('zoom', (event: d3.D3ZoomEvent<SVGSVGElement, unknown>) => {
        g.attr('transform', event.transform.toString());
      });

    svg.call(zoom);

    // Zoom buttons
    const zoomInBtn = document.getElementById('zoom-in');
    const zoomOutBtn = document.getElementById('zoom-out');
    if (zoomInBtn) {
      zoomInBtn.addEventListener('click', () => {
        svg.transition().duration(300).call(zoom.scaleBy, 1.5);
      });
    }
    if (zoomOutBtn) {
      zoomOutBtn.addEventListener('click', () => {
        svg.transition().duration(300).call(zoom.scaleBy, 1 / 1.5);
      });
    }

    // Tooltip
    const tooltip = document.getElementById('map-tooltip')!;

    function getDisplayScore(iso3: string): { value: number; label: string } | null {
      if (currentPillar) {
        const pillarScore = pillarScoreMap.get(iso3)?.get(currentPillar);
        if (pillarScore === undefined) return null;
        const scaled = pillarScore * 9 + 1;
        const label = pillarLabelMap.get(currentPillar) || currentPillar;
        return { value: scaled, label };
      }
      const score = scoreMap.get(iso3);
      if (score === undefined) return null;
      return { value: score, label: '' };
    }

    function showTooltip(
      event: MouseEvent | TouchEvent,
      iso3: string
    ) {
      const name = nameMap.get(iso3);
      const displayScore = getDisplayScore(iso3);
      if (!name && !displayScore) {
        tooltip.classList.add('hidden');
        return;
      }

      const displayName = name || iso3;
      const scoreText = displayScore
        ? displayScore.label
          ? `${displayName} \u2014 ${displayScore.value.toFixed(1)} (${displayScore.label})`
          : `${displayName} \u2014 ${displayScore.value.toFixed(1)}`
        : `${displayName} \u2014 ${translations.nodata}`;

      tooltip.textContent = scoreText;
      tooltip.classList.remove('hidden');

      // Position tooltip
      const containerRect = container!.getBoundingClientRect();
      let clientX: number, clientY: number;
      if ('touches' in event && event.touches.length > 0) {
        clientX = event.touches[0].clientX;
        clientY = event.touches[0].clientY;
      } else if ('clientX' in event) {
        clientX = event.clientX;
        clientY = event.clientY;
      } else {
        return;
      }

      let left = clientX - containerRect.left + 10;
      let top = clientY - containerRect.top + 10;

      // Keep tooltip within container bounds
      const ttRect = tooltip.getBoundingClientRect();
      if (left + ttRect.width > containerRect.width) {
        left = clientX - containerRect.left - ttRect.width - 10;
      }
      if (top + ttRect.height > containerRect.height) {
        top = clientY - containerRect.top - ttRect.height - 10;
      }

      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
    }

    function hideTooltip() {
      tooltip.classList.add('hidden');
    }

    // Touch tracking for mobile
    let lastTappedIso3: string | null = null;

    // Navigation helper
    function navigateToCountry(iso3: string) {
      if (!scoreMap.has(iso3)) return;
      window.location.href = `/${lang}/${countryRoute}/${iso3.toLowerCase()}`;
    }

    // Load topojson and render
    fetch('/world-topo.json')
      .then((res) => res.json())
      .then((topoData) => {
        const countries = topojson.feature(
          topoData as any,
          (topoData as any).objects.countries
        ) as any;

        g.selectAll('path')
          .data(countries.features)
          .enter()
          .append('path')
          .attr('d', path as any)
          .attr('class', 'country-path')
          .attr('fill', (d: any) => {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return isDark() ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;
            return scoreMap.has(iso3)
              ? safetyColorScale(scoreMap.get(iso3)!)
              : isDark()
                ? UNSCORED_COLOR_DARK
                : UNSCORED_COLOR;
          })
          .attr('stroke', strokeColor())
          .attr('stroke-width', 0.5)
          .style('cursor', (d: any) => {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            return iso3 && scoreMap.has(iso3) ? 'pointer' : 'default';
          })
          .on('mouseenter', function (event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            d3.select(this).attr('stroke-width', 1.5);
            showTooltip(event, iso3);
          })
          .on('mousemove', function (event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            showTooltip(event, iso3);
          })
          .on('mouseleave', function () {
            d3.select(this).attr('stroke-width', 0.5);
            hideTooltip();
          })
          .on('click', function (_event: MouseEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;
            navigateToCountry(iso3);
          })
          .on('touchstart', function (event: TouchEvent, d: any) {
            const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
            if (!iso3) return;

            if (iso3 === lastTappedIso3) {
              // Second tap: navigate
              navigateToCountry(iso3);
            } else {
              // First tap: show tooltip
              lastTappedIso3 = iso3;
              showTooltip(event, iso3);
            }
          });

        // Tap on empty area dismisses tooltip
        svg.on('click', (event: MouseEvent) => {
          if ((event.target as Element).tagName === 'svg') {
            lastTappedIso3 = null;
            hideTooltip();
          }
        });

        // Recolor map based on active pillar filter
        function recolorMap(pillarName: string | null) {
          const dark = isDark();
          g.selectAll<SVGPathElement, any>('.country-path')
            .transition()
            .duration(200)
            .attr('fill', (d: any) => {
              const iso3 = ISO_NUMERIC_TO_ALPHA3[String(d.id)];
              if (!iso3) return dark ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;

              if (pillarName) {
                const pillarScore = pillarScoreMap.get(iso3)?.get(pillarName);
                if (pillarScore === undefined) return dark ? UNSCORED_COLOR_DARK : UNSCORED_COLOR;
                // Convert 0-1 pillar score to 1-10 scale
                return safetyColorScale(pillarScore * 9 + 1);
              }

              return scoreMap.has(iso3)
                ? safetyColorScale(scoreMap.get(iso3)!)
                : dark
                  ? UNSCORED_COLOR_DARK
                  : UNSCORED_COLOR;
            });
        }

        // Pill click handlers
        const activePillClasses = ['bg-terracotta-500', 'text-white', 'border-terracotta-500'];
        const inactivePillClasses = ['bg-sand-100', 'dark:bg-sand-800', 'text-sand-600', 'dark:text-sand-300', 'border-sand-300', 'dark:border-sand-600'];

        document.querySelectorAll('.pillar-pill').forEach((btn) => {
          btn.addEventListener('click', () => {
            const pillarId = (btn as HTMLButtonElement).dataset.pillar || 'overall';
            currentPillar = pillarId === 'overall' ? null : pillarId;

            // Update pill styling
            document.querySelectorAll('.pillar-pill').forEach((pill) => {
              const isActive = (pill as HTMLButtonElement).dataset.pillar === pillarId;
              activePillClasses.forEach(c => pill.classList.toggle(c, isActive));
              inactivePillClasses.forEach(c => pill.classList.toggle(c, !isActive));
              // Remove hover classes from active pill
              if (isActive) {
                pill.classList.remove('hover:bg-sand-200', 'dark:hover:bg-sand-700');
              } else {
                pill.classList.add('hover:bg-sand-200', 'dark:hover:bg-sand-700');
              }
            });

            recolorMap(currentPillar);
          });
        });

        // Dark mode observer
        const observer = new MutationObserver(() => {
          recolorMap(currentPillar);
          g.selectAll<SVGPathElement, any>('.country-path')
            .attr('stroke', strokeColor());
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['class'],
        });

        // Responsive resize
        let resizeTimer: ReturnType<typeof setTimeout>;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
            const newRect = container!.getBoundingClientRect();
            const newWidth = newRect.width;
            const newHeight = newRect.height;

            svg.attr('viewBox', `0 0 ${newWidth} ${newHeight}`);
            projection.fitSize([newWidth, newHeight], {
              type: 'Sphere',
            } as d3.GeoPermissibleObjects);

            g.selectAll<SVGPathElement, any>('.country-path').attr(
              'd',
              path as any
            );

            // Reset zoom
            svg.call(zoom.transform, d3.zoomIdentity);
          }, 250);
        });
      })
      .catch((err) => {
        console.error('Failed to load map data:', err);
      });
  }

  // Init on load and after Astro view transitions
  initMap();
  document.addEventListener('astro:after-swap', initMap);
</script>
