---
import type { Lang } from '../i18n/ui';
import { routes } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { loadLatestSnapshot } from '../lib/scores';
import { scoreToColor } from '../lib/colors';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const snapshot = loadLatestSnapshot();
const globalScore = snapshot?.globalScore ?? 0;
const bgColor = scoreToColor(globalScore);
const href = `/${lang}/${routes[lang]['global-safety']}`;
---

{snapshot && globalScore > 0 && (
  <a
    href={href}
    class="group flex items-center justify-center gap-3 mx-auto my-2 px-4 py-2 rounded-lg bg-sand-50 dark:bg-sand-800 border border-sand-200 dark:border-sand-700 hover:border-terracotta-400 dark:hover:border-terracotta-500 transition-colors max-w-md"
  >
    <span
      class="inline-flex items-center justify-center w-10 h-10 rounded-full text-white font-heading font-bold text-lg"
      style={`background-color: ${bgColor};`}
    >
      {globalScore.toFixed(1)}
    </span>
    <span class="text-sm font-medium text-sand-700 dark:text-sand-300">
      {t('global.score_label')}
    </span>
    <svg class="w-4 h-4 text-sand-400 dark:text-sand-500 group-hover:text-terracotta-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
)}
