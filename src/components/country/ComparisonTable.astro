---
import type { ScoredCountry } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { routes } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  country: ScoredCountry;
  allCountries: ScoredCountry[];
  lang: Lang;
}

const { country, allCountries, lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];

// Region mapping (duplicated from RelatedCountries.astro for independence)
const regionMap: Record<string, string> = {
  ALB: 'europe', AND: 'europe', AUT: 'europe', BEL: 'europe', BGR: 'europe',
  BIH: 'europe', BLR: 'europe', CHE: 'europe', CYP: 'europe', CZE: 'europe',
  DEU: 'europe', DNK: 'europe', ESP: 'europe', EST: 'europe', FIN: 'europe',
  FRA: 'europe', GBR: 'europe', GEO: 'europe', GRC: 'europe', HRV: 'europe',
  HUN: 'europe', IRL: 'europe', ISL: 'europe', ITA: 'europe', KOS: 'europe',
  LIE: 'europe', LTU: 'europe', LUX: 'europe', LVA: 'europe', MCO: 'europe',
  MDA: 'europe', MKD: 'europe', MLT: 'europe', MNE: 'europe', NLD: 'europe',
  NOR: 'europe', POL: 'europe', PRT: 'europe', ROU: 'europe', SRB: 'europe',
  SVK: 'europe', SVN: 'europe', SWE: 'europe', UKR: 'europe', XKX: 'europe',
  SMR: 'europe', VAT: 'europe',
  AFG: 'asia', BGD: 'asia', BTN: 'asia', BRN: 'asia', KHM: 'asia',
  CHN: 'asia', IND: 'asia', IDN: 'asia', JPN: 'asia', KAZ: 'asia',
  KGZ: 'asia', LAO: 'asia', MYS: 'asia', MDV: 'asia', MNG: 'asia',
  MMR: 'asia', NPL: 'asia', PRK: 'asia', KOR: 'asia', PAK: 'asia',
  PHL: 'asia', SGP: 'asia', LKA: 'asia', TWN: 'asia', TJK: 'asia',
  THA: 'asia', TLS: 'asia', TKM: 'asia', UZB: 'asia', VNM: 'asia',
  HKG: 'asia', MAC: 'asia',
  ARE: 'middle_east', BHR: 'middle_east', IRN: 'middle_east', IRQ: 'middle_east',
  ISR: 'middle_east', JOR: 'middle_east', KWT: 'middle_east', LBN: 'middle_east',
  OMN: 'middle_east', PSE: 'middle_east', QAT: 'middle_east', SAU: 'middle_east',
  SYR: 'middle_east', TUR: 'middle_east', YEM: 'middle_east', AZE: 'middle_east',
  ARM: 'middle_east',
  DZA: 'africa', AGO: 'africa', BEN: 'africa', BWA: 'africa', BFA: 'africa',
  BDI: 'africa', CPV: 'africa', CMR: 'africa', CAF: 'africa', TCD: 'africa',
  COM: 'africa', COG: 'africa', COD: 'africa', CIV: 'africa', DJI: 'africa',
  EGY: 'africa', GNQ: 'africa', ERI: 'africa', SWZ: 'africa', ETH: 'africa',
  GAB: 'africa', GMB: 'africa', GHA: 'africa', GIN: 'africa', GNB: 'africa',
  KEN: 'africa', LSO: 'africa', LBR: 'africa', LBY: 'africa', MDG: 'africa',
  MWI: 'africa', MLI: 'africa', MRT: 'africa', MUS: 'africa', MAR: 'africa',
  MOZ: 'africa', NAM: 'africa', NER: 'africa', NGA: 'africa', RWA: 'africa',
  STP: 'africa', SEN: 'africa', SYC: 'africa', SLE: 'africa', SOM: 'africa',
  ZAF: 'africa', SSD: 'africa', SDN: 'africa', TZA: 'africa', TGO: 'africa',
  TUN: 'africa', UGA: 'africa', ZMB: 'africa', ZWE: 'africa',
  ARG: 'americas', ATG: 'americas', BHS: 'americas', BRB: 'americas', BLZ: 'americas',
  BOL: 'americas', BRA: 'americas', CAN: 'americas', CHL: 'americas', COL: 'americas',
  CRI: 'americas', CUB: 'americas', DMA: 'americas', DOM: 'americas', ECU: 'americas',
  SLV: 'americas', GRD: 'americas', GTM: 'americas', GUY: 'americas', HTI: 'americas',
  HND: 'americas', JAM: 'americas', MEX: 'americas', NIC: 'americas', PAN: 'americas',
  PRY: 'americas', PER: 'americas', KNA: 'americas', LCA: 'americas', VCT: 'americas',
  SUR: 'americas', TTO: 'americas', USA: 'americas', URY: 'americas', VEN: 'americas',
  AUS: 'oceania', FJI: 'oceania', KIR: 'oceania', MHL: 'oceania', FSM: 'oceania',
  NRU: 'oceania', NZL: 'oceania', PLW: 'oceania', PNG: 'oceania', WSM: 'oceania',
  SLB: 'oceania', TON: 'oceania', TUV: 'oceania', VUT: 'oceania',
};

function getRegion(iso3: string): string {
  return regionMap[iso3] ?? 'other';
}

function getScoreColor(score: number): string {
  if (score >= 7) return 'text-emerald-700 dark:text-emerald-400';
  if (score >= 4) return 'text-amber-700 dark:text-amber-400';
  return 'text-red-700 dark:text-red-400';
}

const currentRegion = getRegion(country.iso3);

// Get up to 4 other countries in same region sorted by score desc, plus current country
const regionCountries = allCountries
  .filter(c => getRegion(c.iso3) === currentRegion && c.iso3 !== country.iso3)
  .sort((a, b) => b.score - a.score)
  .slice(0, 4);

// Build table rows: include current country, sort all by score desc
const tableRows = [...regionCountries, country].sort((a, b) => b.score - a.score);

const heading = t('country.compare_title' as any).replace('{name}', country.name[lang]);

// Pillar order matching ScoredCountry.pillars standard order
const pillarKeys = ['conflict', 'crime', 'health', 'governance', 'environment'] as const;
---

{tableRows.length > 1 && (
  <section class="py-6 px-4 max-w-2xl mx-auto">
    <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-5">
      {heading}
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-sand-300 dark:border-sand-600">
            <th class="text-left py-2 pr-3 text-sand-600 dark:text-sand-400 font-medium">{t('country.compare_country' as any)}</th>
            <th class="text-left py-2 pr-3 text-sand-600 dark:text-sand-400 font-medium">{t('country.compare_score' as any)}</th>
            {pillarKeys.map((key) => (
              <th class="text-left py-2 pr-3 text-sand-600 dark:text-sand-400 font-medium whitespace-nowrap">{t(`country.pillar.${key}` as any)}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {tableRows.map((c) => {
            const isCurrentCountry = c.iso3 === country.iso3;
            const rowClass = isCurrentCountry ? 'bg-terracotta-50 dark:bg-terracotta-900/20' : '';
            const pillarScoreMap = new Map(c.pillars.map(p => [p.name, p.score]));
            return (
              <tr class:list={['border-b border-sand-200 dark:border-sand-700', rowClass]}>
                <td class="py-2 pr-3 font-medium text-sand-800 dark:text-sand-100">
                  <a href={`/${lang}/${r.country}/${c.iso3.toLowerCase()}/`} class="hover:text-terracotta-500 dark:hover:text-terracotta-400">
                    {c.name[lang]}
                  </a>
                </td>
                <td class:list={['py-2 pr-3 font-bold', getScoreColor(c.score)]}>
                  {c.score.toFixed(1)}
                </td>
                {pillarKeys.map((key) => {
                  const pScore = (pillarScoreMap.get(key) ?? 0) * 10;
                  return (
                    <td class:list={['py-2 pr-3', getScoreColor(pScore)]}>
                      {pScore.toFixed(1)}
                    </td>
                  );
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
)}
