---
import type { AdvisoryInfo } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  advisory: AdvisoryInfo;
  sourceName: string;
  sourceKey: string;
  lang: Lang;
}

const { advisory, sourceName, sourceKey, lang } = Astro.props;
const t = useTranslations(lang);

// Advisory level color mapping
function getAdvisoryColor(advisory: AdvisoryInfo, source: string): string {
  if (source === 'uk') {
    // UK FCDO text-based levels
    const text = String(advisory.level).toLowerCase();
    if (text.includes('no travel')) return '#ef4444';
    if (text.includes('essential')) return '#f97316';
    if (text.includes('some parts')) return '#eab308';
    return '#22c55e';
  }
  // All other sources use numeric 1-4 scale
  const level = Number(advisory.level);
  if (level === 1) return '#22c55e';
  if (level === 2) return '#eab308';
  if (level === 3) return '#f97316';
  if (level === 4) return '#ef4444';
  return '#9ca3af';
}

const borderColor = getAdvisoryColor(advisory, sourceKey);

const formattedDate = new Intl.DateTimeFormat(lang, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(new Date(advisory.updatedAt));

const levelText = t('country.advisory.level').replace('{level}', String(advisory.level));
const updatedText = t('country.advisory.updated').replace('{date}', formattedDate);

// Truncate advisory text to 200 characters
const summaryText = advisory.text.length > 200
  ? advisory.text.slice(0, 200).trimEnd() + '...'
  : advisory.text;
---

<div
  class="rounded-lg border border-sand-200 dark:border-sand-700 p-4 bg-white dark:bg-sand-800"
  style={`border-left: 4px solid ${borderColor};`}
>
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-heading font-bold text-sand-800 dark:text-sand-100">
      {sourceName}
    </h3>
    <span
      class="shrink-0 text-xs font-medium px-2 py-1 rounded-full text-white"
      style={`background-color: ${borderColor};`}
    >
      {levelText}
    </span>
  </div>

  <p class="text-sm text-sand-600 dark:text-sand-400 mb-3">
    {summaryText}
  </p>

  <div class="flex items-center justify-between text-xs text-sand-500 dark:text-sand-400">
    <span>{updatedText}</span>
    <a
      href={advisory.url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-terracotta-500 hover:text-terracotta-600 underline"
    >
      Source
    </a>
  </div>
</div>
