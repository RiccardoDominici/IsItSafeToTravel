---
import type { ScoredCountry } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props {
  country: ScoredCountry;
  rank: number;
  totalCountries: number;
  lang: Lang;
}

const { country, rank, totalCountries, lang } = Astro.props;
const t = useTranslations(lang);

const score = country.score;

// Determine risk level
const riskLabels: Record<Lang, { low: string; moderate: string; high: string; very_high: string }> = {
  en: { low: 'Low', moderate: 'Moderate', high: 'High', very_high: 'Very High' },
  it: { low: 'Basso', moderate: 'Moderato', high: 'Alto', very_high: 'Molto Alto' },
  es: { low: 'Bajo', moderate: 'Moderado', high: 'Alto', very_high: 'Muy Alto' },
  fr: { low: 'Faible', moderate: 'Modere', high: 'Eleve', very_high: 'Tres Eleve' },
  pt: { low: 'Baixo', moderate: 'Moderado', high: 'Alto', very_high: 'Muito Alto' },
};

const riskKey = score >= 7 ? 'low' : score >= 5 ? 'moderate' : score >= 3 ? 'high' : 'very_high';
const riskLabel = riskLabels[lang][riskKey];

// Find strongest and weakest pillars
const pillarKeys: Record<string, string> = {
  conflict: 'country.pillar.conflict',
  crime: 'country.pillar.crime',
  health: 'country.pillar.health',
  governance: 'country.pillar.governance',
  environment: 'country.pillar.environment',
};

const sortedPillars = [...country.pillars].sort((a, b) => b.score - a.score);
const strongest = sortedPillars[0];
const weakest = sortedPillars[sortedPillars.length - 1];

const strongestName = t(pillarKeys[strongest.name] as any);
const weakestName = t(pillarKeys[weakest.name] as any);
const strongestScore = (strongest.score * 10).toFixed(1);
const weakestScore = (weakest.score * 10).toFixed(1);

const sourcesCount = country.sources.length;

// Ordinal suffix for ranking
function ordinal(n: number, lang: Lang): string {
  if (lang === 'en') {
    const s = ['th', 'st', 'nd', 'rd'];
    const v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  }
  if (lang === 'fr') return n + (n === 1 ? 'er' : 'e');
  if (lang === 'it') return n + '\u00B0';
  if (lang === 'es') return n + '\u00B0';
  if (lang === 'pt') return n + '\u00BA';
  return String(n);
}

const rankStr = ordinal(rank, lang);
const countryName = country.name[lang];

// Build the paragraph per language
const templates: Record<Lang, string> = {
  en: `${countryName} has a travel safety score of ${score.toFixed(1)}/10, ranking ${rankStr} out of ${totalCountries} countries globally. This classifies it as a ${riskLabel} risk destination. The strongest category is ${strongestName} (${strongestScore}/10) while the main area of concern is ${weakestName} (${weakestScore}/10). Data is sourced from ${sourcesCount}+ public databases and government advisories, updated daily.`,
  it: `${countryName} ha un punteggio di sicurezza di viaggio di ${score.toFixed(1)}/10, classificandosi ${rankStr} su ${totalCountries} paesi a livello globale. Questo lo classifica come una destinazione a rischio ${riskLabel}. La categoria piu forte e ${strongestName} (${strongestScore}/10) mentre la principale area di preoccupazione e ${weakestName} (${weakestScore}/10). I dati provengono da ${sourcesCount}+ database pubblici e avvisi governativi, aggiornati quotidianamente.`,
  es: `${countryName} tiene una puntuacion de seguridad de viaje de ${score.toFixed(1)}/10, ocupando el puesto ${rankStr} de ${totalCountries} paises a nivel mundial. Esto lo clasifica como un destino de riesgo ${riskLabel}. La categoria mas fuerte es ${strongestName} (${strongestScore}/10) mientras que la principal area de preocupacion es ${weakestName} (${weakestScore}/10). Los datos provienen de ${sourcesCount}+ bases de datos publicas y avisos gubernamentales, actualizados diariamente.`,
  fr: `${countryName} a un score de securite de voyage de ${score.toFixed(1)}/10, se classant ${rankStr} sur ${totalCountries} pays dans le monde. Cela le classe comme une destination a risque ${riskLabel}. La categorie la plus forte est ${strongestName} (${strongestScore}/10) tandis que le principal sujet de preoccupation est ${weakestName} (${weakestScore}/10). Les donnees proviennent de ${sourcesCount}+ bases de donnees publiques et avis gouvernementaux, mises a jour quotidiennement.`,
  pt: `${countryName} tem uma pontuacao de seguranca de viagem de ${score.toFixed(1)}/10, classificando-se em ${rankStr} entre ${totalCountries} paises globalmente. Isso o classifica como um destino de risco ${riskLabel}. A categoria mais forte e ${strongestName} (${strongestScore}/10) enquanto a principal area de preocupacao e ${weakestName} (${weakestScore}/10). Os dados sao provenientes de ${sourcesCount}+ bancos de dados publicos e avisos governamentais, atualizados diariamente.`,
};

const summaryText = templates[lang];
---

<p class="text-sm text-sand-600 dark:text-sand-300 leading-relaxed max-w-3xl mx-auto px-4">
  {summaryText}
</p>
