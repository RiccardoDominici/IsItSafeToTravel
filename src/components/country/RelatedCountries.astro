---
import type { ScoredCountry } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { routes } from '../../i18n/ui';
import { getRegion } from '../../lib/regions';

interface Props {
  country: ScoredCountry;
  allCountries: ScoredCountry[];
  lang: Lang;
}

const { country, allCountries, lang } = Astro.props;

const titles: Record<Lang, { heading: string; region: string; similar: string }> = {
  en: { heading: 'Related Countries', region: 'In the same region', similar: 'Similar safety scores' },
  it: { heading: 'Paesi correlati', region: 'Nella stessa regione', similar: 'Punteggi simili' },
  es: { heading: 'Pa\u00edses relacionados', region: 'En la misma regi\u00f3n', similar: 'Puntuaciones similares' },
  fr: { heading: 'Pays similaires', region: 'Dans la m\u00eame r\u00e9gion', similar: 'Scores similaires' },
  pt: { heading: 'Pa\u00edses relacionados', region: 'Na mesma regi\u00e3o', similar: 'Pontua\u00e7\u00f5es similares' },
};

const t = titles[lang];

// Get score color class based on score value
function getScoreBadgeClasses(score: number): string {
  if (score >= 7) return 'bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-300';
  if (score >= 4) return 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300';
  return 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300';
}

const currentRegion = getRegion(country.iso3);
const others = allCountries.filter(c => c.iso3 !== country.iso3);

// Same region, closest scores
const sameRegion = others
  .filter(c => getRegion(c.iso3) === currentRegion)
  .sort((a, b) => Math.abs(a.score - country.score) - Math.abs(b.score - country.score))
  .slice(0, 3);

// Similar scores globally (excluding those already in sameRegion)
const sameRegionIsos = new Set(sameRegion.map(c => c.iso3));
const similarScore = others
  .filter(c => !sameRegionIsos.has(c.iso3))
  .sort((a, b) => Math.abs(a.score - country.score) - Math.abs(b.score - country.score))
  .slice(0, 3);

const r = routes[lang];
function countryUrl(iso3: string): string {
  return `/${lang}/${r.country}/${iso3.toLowerCase()}/`;
}
---

{(sameRegion.length > 0 || similarScore.length > 0) && (
  <section class="py-6 px-4 max-w-2xl mx-auto">
    <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-5">
      {t.heading}
    </h2>

    {sameRegion.length > 0 && (
      <div class="mb-5">
        <h3 class="text-sm font-semibold text-sand-500 dark:text-sand-400 uppercase tracking-wide mb-3">
          {t.region}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {sameRegion.map((c) => (
            <a
              href={countryUrl(c.iso3)}
              class="flex items-center justify-between gap-2 rounded-lg border border-sand-200 dark:border-sand-700 bg-white dark:bg-sand-800 px-4 py-3 hover:border-terracotta-400 dark:hover:border-terracotta-500 transition-colors"
            >
              <span class="text-sm font-medium text-sand-800 dark:text-sand-100 truncate">
                {c.name[lang]}
              </span>
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold whitespace-nowrap ${getScoreBadgeClasses(c.score)}`}>
                {c.score.toFixed(1)}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}

    {similarScore.length > 0 && (
      <div>
        <h3 class="text-sm font-semibold text-sand-500 dark:text-sand-400 uppercase tracking-wide mb-3">
          {t.similar}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {similarScore.map((c) => (
            <a
              href={countryUrl(c.iso3)}
              class="flex items-center justify-between gap-2 rounded-lg border border-sand-200 dark:border-sand-700 bg-white dark:bg-sand-800 px-4 py-3 hover:border-terracotta-400 dark:hover:border-terracotta-500 transition-colors"
            >
              <span class="text-sm font-medium text-sand-800 dark:text-sand-100 truncate">
                {c.name[lang]}
              </span>
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold whitespace-nowrap ${getScoreBadgeClasses(c.score)}`}>
                {c.score.toFixed(1)}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
)}
