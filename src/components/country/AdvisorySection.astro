---
import type { ScoredCountry } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import AdvisoryCard from './AdvisoryCard.astro';

interface Props {
  advisories: ScoredCountry['advisories'];
  lang: Lang;
}

const { advisories, lang } = Astro.props;
const t = useTranslations(lang);

const ADVISORY_KEYS = [
  'us', 'uk', 'ca', 'au', 'de', 'nl', 'jp', 'sk',
  'fr', 'nz', 'ie', 'fi', 'hk', 'br', 'at', 'ph',
  'be', 'dk', 'sg', 'ro', 'rs', 'ee', 'hr', 'ar',
  'it', 'es', 'kr', 'tw', 'cn', 'in',
  'ch', 'se', 'no', 'pl', 'cz', 'hu', 'pt'
] as const;

const PRIMARY_KEYS = ['us', 'uk', 'ca', 'au'];

const sortByDate = (list: { key: string; advisory: any }[]) =>
  list.sort((a, b) => {
    const da = a.advisory.updatedAt ? new Date(a.advisory.updatedAt).getTime() : 0;
    const db = b.advisory.updatedAt ? new Date(b.advisory.updatedAt).getTime() : 0;
    return db - da;
  });

const activeAdvisories = ADVISORY_KEYS
  .filter(key => (advisories as any)[key])
  .map(key => ({ key, advisory: (advisories as any)[key]! }));

const primaryAdvisories = sortByDate(activeAdvisories.filter(a => PRIMARY_KEYS.includes(a.key)));
const additionalAdvisories = sortByDate(activeAdvisories.filter(a => !PRIMARY_KEYS.includes(a.key)));
const hasAny = activeAdvisories.length > 0;

const showMoreText = t('country.advisory.show_more' as any).replace('{count}', String(activeAdvisories.length));
const showLessText = t('country.advisory.show_less' as any);
---

<section class="py-6 px-4 max-w-2xl mx-auto">
  <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
    {t('country.advisories_title')}
  </h2>

  {hasAny ? (
    <div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {primaryAdvisories.map(({ key, advisory }) => (
          <div data-advisory-source={key}>
            <AdvisoryCard
              advisory={advisory}
              sourceName={t(`country.advisory.${key}` as any)}
              sourceKey={key}
              lang={lang}
            />
          </div>
        ))}
      </div>

      {additionalAdvisories.length > 0 && (
        <div class="mt-4">
          <button
            id="toggle-advisories"
            class="text-sm text-terracotta-500 hover:text-terracotta-600 dark:text-terracotta-400 dark:hover:text-terracotta-300 underline cursor-pointer"
            data-show-more={showMoreText}
            data-show-less={showLessText}
          >
            {showMoreText}
          </button>
          <div id="additional-advisories" class="hidden mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            {additionalAdvisories.map(({ key, advisory }) => (
              <div data-advisory-source={key}>
                <AdvisoryCard
                  advisory={advisory}
                  sourceName={t(`country.advisory.${key}` as any)}
                  sourceKey={key}
                  lang={lang}
                />
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  ) : (
    <p class="text-sm text-sand-500 dark:text-sand-400 italic">
      {t('country.no_advisories')}
    </p>
  )}
</section>

<script>
  document.getElementById('toggle-advisories')?.addEventListener('click', () => {
    const el = document.getElementById('additional-advisories');
    const btn = document.getElementById('toggle-advisories');
    if (el && btn) {
      el.classList.toggle('hidden');
      btn.textContent = el.classList.contains('hidden')
        ? btn.dataset.showMore || ''
        : btn.dataset.showLess || '';
    }
  });
</script>
