---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { scoreToColor } from '../../lib/colors';
import { scaleLinear, scaleTime, line, area, timeFormat } from 'd3';
import type { HistoryPoint } from '../../lib/scores';

interface Props {
  data: HistoryPoint[];
  lang: Lang;
}

const { data, lang } = Astro.props;
const t = useTranslations(lang);

// Chart dimensions
const width = 800;
const height = 240;
const margin = { top: 20, right: 20, bottom: 40, left: 50 };
const innerWidth = width - margin.left - margin.right;
const innerHeight = height - margin.top - margin.bottom;

let pathD = '';
let areaD = '';
let endpointCx = 0;
let endpointCy = 0;
let endpointColor = '#9ca3af';
const showChart = data.length >= 2;
const showAccumulating = data.length < 7;

// Axis tick data
let xTicks: Array<{ x: number; label: string }> = [];
let yTicks: Array<{ y: number; label: string }> = [];

// Chart points for tooltip interactivity (SVG coordinates including margin offset)
let chartPoints: Array<{ date: string; score: number; cx: number; cy: number }> = [];

if (showChart) {
  const dates = data.map(d => new Date(d.date));
  const x = scaleTime()
    .domain([dates[0], dates[dates.length - 1]])
    .range([0, innerWidth]);

  const y = scaleLinear()
    .domain([1, 10])
    .range([innerHeight, 0]);

  const lineGen = line<HistoryPoint>()
    .x(d => x(new Date(d.date)))
    .y(d => y(d.score));

  const areaGen = area<HistoryPoint>()
    .x(d => x(new Date(d.date)))
    .y0(innerHeight)
    .y1(d => y(d.score));

  pathD = lineGen(data) ?? '';
  areaD = areaGen(data) ?? '';

  const lastPoint = data[data.length - 1];
  endpointCx = x(new Date(lastPoint.date));
  endpointCy = y(lastPoint.score);
  endpointColor = scoreToColor(lastPoint.score);

  // X axis ticks (5-7 evenly spaced dates)
  const tickCount = Math.min(6, dates.length);
  const fmt = timeFormat('%b %d');
  for (let i = 0; i < tickCount; i++) {
    const idx = Math.round((i / (tickCount - 1)) * (dates.length - 1));
    xTicks.push({ x: x(dates[idx]), label: fmt(dates[idx]) });
  }

  // Y axis ticks (scores 2, 4, 6, 8, 10)
  yTicks = [2, 4, 6, 8, 10].map(s => ({ y: y(s), label: String(s) }));

  // Build chart points for tooltip (cx/cy include margin offset for SVG coordinate space)
  chartPoints = data.map(d => ({
    date: d.date,
    score: d.score,
    cx: x(new Date(d.date)) + margin.left,
    cy: y(d.score) + margin.top,
  }));
}
---

<section class="py-6 px-4 max-w-2xl mx-auto">
  <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
    {t('country.trend_title')}
  </h2>

  {showChart ? (
    <div>
      <div id="trend-chart-container" class="relative" data-history={JSON.stringify(chartPoints)}>
        <svg
          viewBox={`0 0 ${width} ${height}`}
          class="w-full text-sand-700 dark:text-sand-300"
          role="img"
          aria-label={t('country.trend_title')}
        >
          <defs>
            <linearGradient id="trendGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#c47a5a" stop-opacity="0.3" />
              <stop offset="100%" stop-color="#c47a5a" stop-opacity="0.05" />
            </linearGradient>
          </defs>

          <g transform={`translate(${margin.left}, ${margin.top})`}>
            {/* Y gridlines */}
            {yTicks.map(tick => (
              <line
                x1={0} y1={tick.y}
                x2={innerWidth} y2={tick.y}
                stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.3"
              />
            ))}

            {/* Area fill */}
            <path
              d={areaD}
              fill="url(#trendGradient)"
            />

            {/* Trend line */}
            <path
              d={pathD}
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linejoin="round"
              stroke-linecap="round"
            />

            {/* Endpoint dot */}
            <circle cx={endpointCx} cy={endpointCy} r="4" fill={endpointColor} />

            {/* Y axis labels */}
            {yTicks.map(tick => (
              <text
                x={-10} y={tick.y}
                text-anchor="end"
                dominant-baseline="middle"
                class="text-xs fill-sand-500 dark:fill-sand-400"
                font-size="12"
              >
                {tick.label}
              </text>
            ))}

            {/* X axis labels */}
            {xTicks.map(tick => (
              <text
                x={tick.x} y={innerHeight + 25}
                text-anchor="middle"
                class="text-xs fill-sand-500 dark:fill-sand-400"
                font-size="11"
              >
                {tick.label}
              </text>
            ))}
          </g>
        </svg>

        <div id="trend-tooltip" class="absolute hidden pointer-events-none bg-sand-100 dark:bg-sand-800 border border-terracotta-300 dark:border-terracotta-600 rounded px-2 py-1 text-sm shadow-md z-10 whitespace-nowrap" />
      </div>

      {showAccumulating && (
        <p class="text-xs text-sand-500 dark:text-sand-400 mt-2 italic">
          {t('country.trend_accumulating')}
        </p>
      )}
    </div>
  ) : (
    <p class="text-sm text-sand-500 dark:text-sand-400 italic">
      {t('country.trend_accumulating')}
    </p>
  )}
</section>

<script>
  const container = document.getElementById('trend-chart-container');
  if (container) {
    const tooltip = document.getElementById('trend-tooltip');
    const svg = container.querySelector('svg');
    const points: Array<{date: string; score: number; cx: number; cy: number}> = JSON.parse(container.dataset.history || '[]');

    if (svg && tooltip && points.length > 0) {
      const svgRect = () => svg.getBoundingClientRect();
      const viewBox = svg.viewBox.baseVal;

      const showTooltip = (point: {date: string; score: number; cx: number; cy: number}) => {
        const rect = svgRect();
        const scaleX = rect.width / viewBox.width;
        const scaleY = rect.height / viewBox.height;

        // Format date with locale awareness
        const d = new Date(point.date);
        const dateStr = d.toLocaleDateString(
          document.documentElement.lang === 'it' ? 'it-IT' : 'en-US',
          { month: 'short', day: 'numeric', year: 'numeric' }
        );

        tooltip.textContent = `${dateStr}: ${point.score.toFixed(1)}`;
        tooltip.classList.remove('hidden');

        // Position tooltip above the point
        const tooltipX = point.cx * scaleX - tooltip.offsetWidth / 2;
        const tooltipY = point.cy * scaleY - tooltip.offsetHeight - 8;

        tooltip.style.left = `${Math.max(0, Math.min(tooltipX, rect.width - tooltip.offsetWidth))}px`;
        tooltip.style.top = `${Math.max(0, tooltipY)}px`;
      };

      const hideTooltip = () => {
        tooltip.classList.add('hidden');
      };

      // Desktop: mousemove finds nearest point
      svg.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = svgRect();
        const mouseX = (e.clientX - rect.left) / rect.width * viewBox.width;

        let nearest = points[0];
        let minDist = Infinity;
        for (const p of points) {
          const dist = Math.abs(p.cx - mouseX);
          if (dist < minDist) { minDist = dist; nearest = p; }
        }
        showTooltip(nearest);
      });

      svg.addEventListener('mouseleave', hideTooltip);

      // Mobile: tap to show, tap elsewhere to dismiss
      svg.addEventListener('touchstart', (e: TouchEvent) => {
        e.preventDefault();
        const touch = e.touches[0];
        const rect = svgRect();
        const touchX = (touch.clientX - rect.left) / rect.width * viewBox.width;

        let nearest = points[0];
        let minDist = Infinity;
        for (const p of points) {
          const dist = Math.abs(p.cx - touchX);
          if (dist < minDist) { minDist = dist; nearest = p; }
        }
        showTooltip(nearest);
      }, { passive: false });

      document.addEventListener('touchstart', (e: TouchEvent) => {
        if (!container.contains(e.target as Node)) hideTooltip();
      });
    }
  }
</script>
