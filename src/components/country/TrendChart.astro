---
import type { Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { scoreToColor } from '../../lib/colors';
import type { HistoryPoint } from '../../lib/scores';

interface Props {
  data: HistoryPoint[];
  pillarData?: Record<string, HistoryPoint[]> | null;
  lang: Lang;
  advisorySources?: { key: string; name: string }[];
}

const { data, pillarData, lang, advisorySources = [] } = Astro.props;
const t = useTranslations(lang);

const uniqueScores = new Set(data.map(d => d.score));
const isFlat = uniqueScores.size <= 1;
const showChart = data.length >= 2 && !isFlat;
const showAccumulating = data.length < 7;
const stableScore = isFlat && data.length >= 2 ? data[0].score : null;

// Pillar filter pills for trend chart
const pillarFilters = [
  { id: 'overall', label: t('filter.overall'), weight: null as number | null },
  { id: 'conflict', label: t('country.pillar.conflict'), weight: 25 },
  { id: 'crime', label: t('country.pillar.crime'), weight: 20 },
  { id: 'health', label: t('country.pillar.health'), weight: 20 },
  { id: 'governance', label: t('country.pillar.governance'), weight: 20 },
  { id: 'environment', label: t('country.pillar.environment'), weight: 15 },
];

// Show chart section if we have pillar data even if composite is flat
const hasPillarData = pillarData && Object.keys(pillarData).length > 0;
const showChartSection = showChart || (hasPillarData && data.length >= 2);
---

<section class="py-6 px-4 max-w-2xl mx-auto">
  <h2 class="text-xl md:text-2xl font-heading font-bold text-sand-800 dark:text-sand-100 mb-4">
    {t('country.trend_title')}
  </h2>

  {showChartSection ? (
    <div>
      {hasPillarData && (
        <div id="trend-filter-wrapper" class="relative inline-block mb-3" data-advisory-sources={JSON.stringify(advisorySources)} data-all-sources-label={t('filter.all_sources')}>
          <button
            id="trend-filter-toggle"
            class="flex items-center gap-1.5 px-3 py-1.5 bg-sand-100 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg text-xs font-medium text-sand-700 dark:text-sand-200 hover:bg-sand-200 dark:hover:bg-sand-700 cursor-pointer transition-colors"
            type="button"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 4h14M5 8h10M7 12h6M9 16h2" stroke-linecap="round" />
            </svg>
            <span>Filtri</span>
            <svg class="w-2.5 h-2.5 opacity-50" viewBox="0 0 12 12" fill="currentColor">
              <path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div id="trend-filter-dropdown" class="hidden absolute top-full left-0 mt-1 p-1.5 bg-sand-50/95 dark:bg-sand-800/95 backdrop-blur-sm border border-sand-300 dark:border-sand-600 rounded-lg shadow-lg min-w-[200px] z-20">
            <div class="flex flex-col gap-0.5" id="trend-pillar-filter">
              {pillarFilters.map(f => (
                <button
                  class={`trend-pillar-pill px-2.5 py-1.5 text-xs font-medium rounded-md border transition-colors cursor-pointer text-left ${f.id === 'overall' ? 'bg-terracotta-500 text-white border-terracotta-500' : 'bg-transparent text-sand-600 dark:text-sand-300 border-transparent hover:bg-sand-200 dark:hover:bg-sand-700'}`}
                  data-pillar={f.id}
                  data-weight={f.weight !== null ? f.weight : ''}
                >
                  {f.weight !== null ? f.label : f.label}
                </button>
              ))}
            </div>
            {advisorySources.length > 0 && (
              <Fragment>
                <div class="border-t border-sand-200 dark:border-sand-700 my-2"></div>
                <div class="text-[10px] font-medium text-sand-500 dark:text-sand-400 px-1 mb-1" id="trend-source-filter-header">
                  {t('filter.sources')} ({advisorySources.length})
                </div>
                <div class="flex flex-col gap-0 max-h-[200px] overflow-y-auto" id="trend-source-filter-list">
                  <!-- Populated dynamically -->
                </div>
              </Fragment>
            )}
          </div>
        </div>
      )}
      <div id="trend-chart-container" class="relative" data-history={JSON.stringify(data)} data-pillar-history={pillarData ? JSON.stringify(pillarData) : ''} data-lang={lang}>
        <div id="trend-chart-placeholder" class="flex items-center justify-center w-full bg-sand-50 dark:bg-sand-900 rounded" style="aspect-ratio: 800/240;">
          <span class="text-sm text-sand-400 dark:text-sand-500 animate-pulse">Loading chart...</span>
        </div>
        <svg id="trend-chart-svg" viewBox="0 0 800 240" class="w-full text-sand-700 dark:text-sand-300 hidden" role="img" aria-label={t('country.trend_title')}></svg>
        <div id="trend-tooltip" class="absolute hidden pointer-events-none bg-sand-100 dark:bg-sand-800 border border-terracotta-300 dark:border-terracotta-600 rounded px-2 py-1 text-sm shadow-md z-10 whitespace-nowrap"></div>
      </div>
      <div class="flex flex-wrap items-center gap-2 mt-2">
        <div class="time-range-selector inline-flex bg-sand-100 dark:bg-sand-800 border border-sand-300 dark:border-sand-600 rounded-lg p-0.5" role="group" aria-label="Time range">
          <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-terracotta-500 text-white" data-range="1m" type="button" aria-pressed="true">1M</button>
          <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="6m" type="button">6M</button>
          <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="1y" type="button">1Y</button>
          <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="10y" type="button">10Y</button>
          <button class="time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" data-range="max" type="button">MAX</button>
        </div>
        <button id="trend-reset-btn" class="hidden px-2.5 py-1 text-xs font-medium rounded-md border border-sand-300 dark:border-sand-600 transition-colors cursor-pointer bg-sand-100 dark:bg-sand-800 text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700" type="button">Reset</button>
      </div>

      {showAccumulating && (
        <p class="text-xs text-sand-500 dark:text-sand-400 mt-2 italic">
          {t('country.trend_accumulating')}
        </p>
      )}
    </div>
  ) : stableScore !== null ? (
    <div class="text-center py-8">
      <div class="inline-flex items-center gap-3 px-6 py-4 rounded-xl bg-sand-100 dark:bg-sand-800 border border-sand-200 dark:border-sand-700">
        <span class="text-3xl font-heading font-bold" style={`color: ${scoreToColor(stableScore)}`}>{stableScore.toFixed(1)}</span>
        <span class="text-sand-600 dark:text-sand-400 text-sm">{t('country.trend_stable')}</span>
      </div>
    </div>
  ) : (
    <p class="text-sm text-sand-500 dark:text-sand-400 italic">
      {t('country.trend_accumulating')}
    </p>
  )}
</section>

<script>
  import { scoreToColor } from '../../lib/colors';

  function initTrendChart(): void {
    // Dynamic import of D3 — only loaded when chart is in view
    import('d3').then(({ scaleLinear, scaleTime, line, area, utcFormat, brushX, select, easeCubicOut }) => {

    function smartDateFormat(dates: Date[]): (d: Date) => string {
      const first = dates[0], last = dates[dates.length - 1];
      if (first.getUTCFullYear() !== last.getUTCFullYear()) {
        return utcFormat('%b %Y');
      } else if (first.getUTCMonth() !== last.getUTCMonth()) {
        return utcFormat('%b %d');
      } else {
        return utcFormat('%d');
      }
    }

    const container = document.getElementById('trend-chart-container');
    if (container) {
      // Remove placeholder and show SVG
      const placeholder = document.getElementById('trend-chart-placeholder');
      const svgEl = document.getElementById('trend-chart-svg');
      if (placeholder) placeholder.remove();
      if (svgEl) svgEl.classList.remove('hidden');
    const svg = document.getElementById('trend-chart-svg') as unknown as SVGSVGElement;
    const tooltip = document.getElementById('trend-tooltip')!;
    const resetBtn = document.getElementById('trend-reset-btn')!;
    const lang = container.dataset.lang || 'en';

    interface HistoryPoint { date: string; score: number; dc?: number; }
    const fullData: HistoryPoint[] = JSON.parse(container.dataset.history || '[]');

    // Parse pillar history data
    const pillarHistoryRaw = container.dataset.pillarHistory;
    const pillarHistory: Record<string, HistoryPoint[]> | null = pillarHistoryRaw ? JSON.parse(pillarHistoryRaw) : null;

    // Track current pillar filter (null = overall/composite)
    let currentPillar: string | null = null;

    // Get chart data for a given pillar (or overall if null)
    function getChartData(pillarName: string | null): HistoryPoint[] {
      if (!pillarName || pillarName === 'overall') return fullData;
      if (!pillarHistory || !pillarHistory[pillarName] || pillarHistory[pillarName].length === 0) return fullData;
      // Convert 0-1 normalized scores to 1-10 scale
      return pillarHistory[pillarName].map(p => ({
        date: p.date,
        score: p.score * 9 + 1,
      }));
    }

    if (fullData.length >= 2) {
      // Chart dimensions
      const width = 800;
      const height = 240;
      const margin = { top: 20, right: 20, bottom: 40, left: 50 };
      const innerWidth = width - margin.left - margin.right;
      const innerHeight = height - margin.top - margin.bottom;

      // Current display data (for tooltip)
      let currentData: HistoryPoint[] = fullData;

      // Current scales (for tooltip)
      let xScale: ReturnType<typeof scaleTime<number, number>>;
      let yScale: ReturnType<typeof scaleLinear<number, number>>;

      // Pinned tooltip state
      let pinnedPoint: HistoryPoint | null = null;

      // Slope computation for magnet snap
      function computeSlopes(data: HistoryPoint[]): number[] {
        const slopes: number[] = [];
        for (let i = 0; i < data.length; i++) {
          let slope = 0;
          if (i > 0) slope = Math.abs(data[i].score - data[i - 1].score);
          if (i < data.length - 1) slope = Math.max(slope, Math.abs(data[i + 1].score - data[i].score));
          slopes.push(slope);
        }
        return slopes;
      }

      let currentSlopes: number[] = computeSlopes(fullData);
      let avgSlope = currentSlopes.reduce((a, b) => a + b, 0) / currentSlopes.length;

      function findNearestWithSnap(mouseX: number, data: HistoryPoint[], slopes: number[], avg: number): HistoryPoint {
        let nearest = data[0];
        let minDist = Infinity;
        for (let i = 0; i < data.length; i++) {
          const px = xScale(new Date(data[i].date + 'T00:00:00Z'));
          const radius = slopes[i] > avg ? 2 : 1;
          const dist = Math.abs(px - mouseX) / radius;
          if (dist < minDist) { minDist = dist; nearest = data[i]; }
        }
        return nearest;
      }

      function computeYDomain(data: HistoryPoint[]): [number, number] {
        const scores = data.map(d => d.score);
        const min = Math.min(...scores);
        const max = Math.max(...scores);
        const range = max - min;
        const pad = Math.max(range * 0.2, 0.2);
        return [
          Math.max(1, Math.floor((min - pad) * 2) / 2),
          Math.min(10, Math.ceil((max + pad) * 2) / 2),
        ];
      }

      function isInsufficient(p: HistoryPoint): boolean {
        return p.dc !== undefined && p.dc < 0.15;
      }

      function renderChart(filteredData: HistoryPoint[], allData: HistoryPoint[]): void {
        currentData = filteredData;
        pinnedPoint = null;

        // Recompute slopes
        currentSlopes = computeSlopes(filteredData);
        avgSlope = currentSlopes.length > 0 ? currentSlopes.reduce((a, b) => a + b, 0) / currentSlopes.length : 0;

        const dates = filteredData.map(d => new Date(d.date + 'T00:00:00Z'));
        xScale = scaleTime()
          .domain([dates[0], dates[dates.length - 1]])
          .range([0, innerWidth]);

        const [yMin, yMax] = computeYDomain(filteredData);
        yScale = scaleLinear()
          .domain([yMin, yMax])
          .range([innerHeight, 0]);

        const lineGen = line<HistoryPoint>()
          .x(d => xScale(new Date(d.date + 'T00:00:00Z')))
          .y(d => yScale(d.score));

        const areaGen = area<HistoryPoint>()
          .x(d => xScale(new Date(d.date + 'T00:00:00Z')))
          .y0(innerHeight)
          .y1(d => yScale(d.score));

        // Split data into segments by data quality (dc < 0.5 = insufficient)

        interface Segment { points: HistoryPoint[]; insufficient: boolean; }
        const segments: Segment[] = [];
        let currentSeg: Segment | null = null;
        for (const p of filteredData) {
          const insuf = isInsufficient(p);
          if (!currentSeg || currentSeg.insufficient !== insuf) {
            // Overlap: connect segments by including the last point of prev segment
            if (currentSeg && currentSeg.points.length > 0) {
              const overlap = currentSeg.points[currentSeg.points.length - 1];
              currentSeg = { points: [overlap], insufficient: insuf };
            } else {
              currentSeg = { points: [], insufficient: insuf };
            }
            segments.push(currentSeg);
          }
          currentSeg.points.push(p);
        }

        // Build segmented paths
        let segmentPaths = '';
        for (const seg of segments) {
          if (seg.points.length < 2) continue;
          const segLineD = lineGen(seg.points) ?? '';
          const segAreaD = areaGen(seg.points) ?? '';
          if (seg.insufficient) {
            segmentPaths += `<path d="${segAreaD}" fill="currentColor" fill-opacity="0.06" clip-path="url(#chart-clip)" />`;
            segmentPaths += `<path d="${segLineD}" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="6 4" stroke-opacity="0.35" stroke-linejoin="round" stroke-linecap="round" clip-path="url(#chart-clip)" />`;
          } else {
            segmentPaths += `<path class="area-path" d="${segAreaD}" fill="url(#trendGradient)" clip-path="url(#chart-clip)" />`;
            segmentPaths += `<path class="line-path" d="${segLineD}" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" clip-path="url(#chart-clip)" />`;
          }
        }

        const lastPoint = filteredData[filteredData.length - 1];
        const endCx = xScale(new Date(lastPoint.date + 'T00:00:00Z'));
        const endCy = yScale(lastPoint.score);
        const endColor = isInsufficient(lastPoint) ? '#9ca3af' : scoreToColor(lastPoint.score);

        // Y gridlines and labels (dynamic based on data range)
        const yTickCount = 5;
        const yTickStep = (yMax - yMin) / (yTickCount - 1);
        let gridLines = '';
        let yLabels = '';
        for (let i = 0; i < yTickCount; i++) {
          const val = yMin + i * yTickStep;
          const yPos = yScale(val);
          gridLines += `<line x1="0" y1="${yPos}" x2="${innerWidth}" y2="${yPos}" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.3" />`;
          yLabels += `<text x="-10" y="${yPos}" text-anchor="end" dominant-baseline="middle" class="text-xs fill-sand-500 dark:fill-sand-400" font-size="12">${val.toFixed(1)}</text>`;
        }

        // X axis ticks - smart format, remove overlapping labels (keep most recent)
        const tickCount = Math.min(6, dates.length);
        const fmt = smartDateFormat(dates);
        const ticks: {x: number, label: string}[] = [];
        for (let i = 0; i < tickCount; i++) {
          const idx = Math.round((i / (tickCount - 1)) * (dates.length - 1));
          ticks.push({ x: xScale(dates[idx]), label: fmt(dates[idx]) });
        }
        // Remove overlapping ticks from right to left, keeping the most recent
        const minGap = 50;
        for (let i = ticks.length - 2; i >= 0; i--) {
          if (ticks[i + 1].x - ticks[i].x < minGap) {
            ticks.splice(i, 1);
          }
        }
        let xLabels = '';
        for (let ti = 0; ti < ticks.length; ti++) {
          const t = ticks[ti];
          const anchor = ti === ticks.length - 1 ? 'end' : ti === 0 ? 'start' : 'middle';
          xLabels += `<text x="${t.x}" y="${innerHeight + 25}" text-anchor="${anchor}" class="text-xs fill-sand-500 dark:fill-sand-400" font-size="11">${t.label}</text>`;
        }

        svg.innerHTML = `
          <defs>
            <linearGradient id="trendGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#c47a5a" stop-opacity="0.3" />
              <stop offset="100%" stop-color="#c47a5a" stop-opacity="0.05" />
            </linearGradient>
            <clipPath id="chart-clip"><rect x="0" y="0" width="${innerWidth}" height="${innerHeight}"/></clipPath>
          </defs>
          <g class="chart-main" transform="translate(${margin.left}, ${margin.top})">
            ${gridLines}
            ${segmentPaths}
            <circle cx="${endCx}" cy="${endCy}" r="4" fill="${endColor}" />
            ${yLabels}
            ${xLabels}
          </g>
        `;

        // Re-attach brush after innerHTML rebuild
        attachBrush(allData);
      }

      function attachBrush(allData: HistoryPoint[]): void {
        const mainGroup = svg.querySelector('.chart-main');
        if (!mainGroup) return;

        const brush = brushX()
          .extent([[0, 0], [innerWidth, innerHeight]])
          .on('end', (event: any) => {
            if (!event.selection) return;
            const [x0, x1] = event.selection as [number, number];
            const date0 = xScale.invert(x0);
            const date1 = xScale.invert(x1);

            const filtered = allData.filter(d => {
              const dt = new Date(d.date + 'T00:00:00Z');
              return dt >= date0 && dt <= date1;
            });

            if (filtered.length < 2) return;

            // Store old paths for transition
            const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
            const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

            renderChart(filtered, allData);
            resetBtn.classList.remove('hidden');
            currentTimeRange = 'custom';

            // Deselect all time range buttons
            document.querySelectorAll('.time-range-btn').forEach(btn => {
              const el = btn as HTMLElement;
              el.className = 'time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700';
              el.setAttribute('aria-pressed', 'false');
            });

            // Animate transition
            animatePaths(oldLinePath, oldAreaPath);
          });

        const brushGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        brushGroup.setAttribute('class', 'brush');
        mainGroup.appendChild(brushGroup);

        select(brushGroup).call(brush);

        // Style the brush selection
        const style = document.createElementNS('http://www.w3.org/2000/svg', 'style');
        style.textContent = `.brush .selection { fill: #c47a5a; fill-opacity: 0.15; stroke: #c47a5a; stroke-opacity: 0.4; }`;
        svg.insertBefore(style, svg.firstChild);
      }

      function animatePaths(oldLineD: string, oldAreaD: string): void {
        const linePath = svg.querySelector('.line-path');
        const areaPath = svg.querySelector('.area-path');
        if (linePath && oldLineD) {
          const newLineD = linePath.getAttribute('d') || '';
          select(linePath).attr('d', oldLineD)
            .transition().duration(300).ease(easeCubicOut)
            .attr('d', newLineD);
        }
        if (areaPath && oldAreaD) {
          const newAreaD = areaPath.getAttribute('d') || '';
          select(areaPath).attr('d', oldAreaD)
            .transition().duration(300).ease(easeCubicOut)
            .attr('d', newAreaD);
        }
      }

      // Reset button handler — reset to full date range of current pillar
      resetBtn.addEventListener('click', () => {
        applyTimeRange('1m');
      });

      // Filter dropdown toggle
      const trendFilterToggle = document.getElementById('trend-filter-toggle');
      const trendFilterDropdown = document.getElementById('trend-filter-dropdown');

      trendFilterToggle?.addEventListener('click', () => {
        trendFilterDropdown?.classList.toggle('hidden');
      });

      document.addEventListener('click', (e) => {
        const wrapper = document.getElementById('trend-filter-wrapper');
        if (wrapper && !wrapper.contains(e.target as Node)) {
          trendFilterDropdown?.classList.add('hidden');
        }
      });

      // Pillar filter pill click handlers
      const pillarPills = document.querySelectorAll('.trend-pillar-pill');
      const activeClass = 'bg-terracotta-500 text-white border-terracotta-500';
      const inactiveClass = 'bg-transparent text-sand-600 dark:text-sand-300 border-transparent hover:bg-sand-200 dark:hover:bg-sand-700';

      pillarPills.forEach(pill => {
        pill.addEventListener('click', () => {
          const pillarId = (pill as HTMLElement).dataset.pillar || 'overall';
          currentPillar = pillarId === 'overall' ? null : pillarId;

          const baseData = getChartData(currentPillar);
          const newData = filterByTimeRange(baseData, currentTimeRange);
          if (newData.length < 2) return;

          const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
          const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

          renderChart(newData, baseData);
          animatePaths(oldLinePath, oldAreaPath);
          resetBtn.classList.add('hidden');

          pillarPills.forEach(p => {
            const el = p as HTMLElement;
            activeClass.split(' ').forEach(c => el.classList.remove(c));
            inactiveClass.split(' ').forEach(c => el.classList.remove(c));
            if (el.dataset.pillar === pillarId) {
              activeClass.split(' ').forEach(c => el.classList.add(c));
            } else {
              inactiveClass.split(' ').forEach(c => el.classList.add(c));
            }
          });

          trendFilterDropdown?.classList.add('hidden');
        });
      });

      // Source filter for advisory cards
      const trendFilterWrapper = document.getElementById('trend-filter-wrapper');
      const trendSourceFilterList = document.getElementById('trend-source-filter-list');
      if (trendFilterWrapper && trendSourceFilterList) {
        const advSources: { key: string; name: string }[] = JSON.parse(trendFilterWrapper.dataset.advisorySources || '[]');
        if (advSources.length > 0) {
          const trendEnabledSources = new Set<string>(advSources.map(s => s.key));

          // "All sources" toggle
          const allLabel = document.createElement('label');
          allLabel.className = 'flex items-center gap-2 px-2 py-1 text-xs rounded-md hover:bg-sand-200 dark:hover:bg-sand-700 cursor-pointer font-medium';
          const allSourcesText = trendFilterWrapper.dataset.allSourcesLabel || 'All sources';
          allLabel.innerHTML = `<input type="checkbox" checked class="accent-terracotta-500 w-3 h-3" id="trend-source-all-toggle" /><span class="text-sand-600 dark:text-sand-300">${allSourcesText}</span>`;
          trendSourceFilterList.appendChild(allLabel);

          // Individual checkboxes
          for (const src of advSources) {
            const label = document.createElement('label');
            label.className = 'flex items-center gap-2 px-2 py-0.5 text-xs rounded-md hover:bg-sand-200 dark:hover:bg-sand-700 cursor-pointer';
            label.innerHTML = `<input type="checkbox" checked class="accent-terracotta-500 w-3 h-3 trend-source-checkbox" data-source="${src.key}" /><span class="text-sand-600 dark:text-sand-300 truncate">${src.name}</span>`;
            trendSourceFilterList.appendChild(label);
          }

          function applyTrendSourceFilter() {
            document.querySelectorAll('[data-advisory-source]').forEach((el) => {
              const src = (el as HTMLElement).dataset.advisorySource;
              if (src) {
                (el as HTMLElement).classList.toggle('hidden', !trendEnabledSources.has(src));
              }
            });
          }

          // Prevent dropdown close
          trendSourceFilterList.addEventListener('click', (e) => {
            e.stopPropagation();
          });

          // All toggle
          const trendAllToggle = document.getElementById('trend-source-all-toggle') as HTMLInputElement | null;
          trendAllToggle?.addEventListener('change', () => {
            const checked = trendAllToggle.checked;
            document.querySelectorAll('.trend-source-checkbox').forEach((cb) => {
              const input = cb as HTMLInputElement;
              input.checked = checked;
              const s = input.dataset.source;
              if (s) {
                if (checked) trendEnabledSources.add(s);
                else trendEnabledSources.delete(s);
              }
            });
            applyTrendSourceFilter();
          });

          // Individual handlers
          trendSourceFilterList.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            if (!target.classList.contains('trend-source-checkbox')) return;
            const s = target.dataset.source;
            if (!s) return;
            if (target.checked) trendEnabledSources.add(s);
            else trendEnabledSources.delete(s);

            const allCbs = document.querySelectorAll('.trend-source-checkbox') as NodeListOf<HTMLInputElement>;
            const checkedCount = [...allCbs].filter(cb => cb.checked).length;
            if (trendAllToggle) {
              trendAllToggle.checked = checkedCount === allCbs.length;
              trendAllToggle.indeterminate = checkedCount > 0 && checkedCount < allCbs.length;
            }
            applyTrendSourceFilter();
          });
        }
      }

      // Tooltip
      const svgRect = () => svg.getBoundingClientRect();
      const viewBox = svg.viewBox.baseVal;

      // SVG crosshair elements (persistent, moved on hover)
      function ensureCrosshairElements(): { vLine: SVGLineElement; dot: SVGCircleElement } {
        let vLine = svg.querySelector('.crosshair-line') as SVGLineElement | null;
        let dot = svg.querySelector('.crosshair-dot') as SVGCircleElement | null;
        const mainGroup = svg.querySelector('.chart-main');
        if (!mainGroup) return { vLine: vLine!, dot: dot! };
        if (!vLine) {
          vLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          vLine.setAttribute('class', 'crosshair-line');
          vLine.setAttribute('stroke', '#c47a5a');
          vLine.setAttribute('stroke-width', '1');
          vLine.setAttribute('stroke-dasharray', '3 3');
          vLine.setAttribute('opacity', '0.6');
          vLine.setAttribute('y1', '0');
          vLine.setAttribute('y2', String(innerHeight));
          vLine.style.display = 'none';
          mainGroup.appendChild(vLine);
        }
        if (!dot) {
          dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          dot.setAttribute('class', 'crosshair-dot');
          dot.setAttribute('r', '5');
          dot.setAttribute('stroke', '#fff');
          dot.setAttribute('stroke-width', '2');
          dot.style.display = 'none';
          mainGroup.appendChild(dot);
        }
        return { vLine, dot };
      }

      function showCrosshair(point: HistoryPoint): void {
        const { vLine, dot } = ensureCrosshairElements();
        if (!vLine || !dot) return;
        const cx = xScale(new Date(point.date + 'T00:00:00Z'));
        const cy = yScale(point.score);
        vLine.setAttribute('x1', String(cx));
        vLine.setAttribute('x2', String(cx));
        vLine.style.display = '';
        dot.setAttribute('cx', String(cx));
        dot.setAttribute('cy', String(cy));
        dot.setAttribute('fill', scoreToColor(point.score));
        dot.style.display = '';
      }

      function hideCrosshair(): void {
        const vLine = svg.querySelector('.crosshair-line') as SVGElement | null;
        const dot = svg.querySelector('.crosshair-dot') as SVGElement | null;
        if (vLine) vLine.style.display = 'none';
        if (dot) dot.style.display = 'none';
      }

      function removePinnedCircle(): void {
        svg.querySelector('.pinned-circle')?.remove();
      }

      function drawPinnedCircle(point: HistoryPoint): void {
        removePinnedCircle();
        const mainGroup = svg.querySelector('.chart-main');
        if (!mainGroup) return;
        const cx = xScale(new Date(point.date + 'T00:00:00Z'));
        const cy = yScale(point.score);
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('class', 'pinned-circle');
        circle.setAttribute('cx', String(cx));
        circle.setAttribute('cy', String(cy));
        circle.setAttribute('r', '6');
        circle.setAttribute('fill', scoreToColor(point.score));
        circle.setAttribute('stroke', '#fff');
        circle.setAttribute('stroke-width', '2');
        mainGroup.appendChild(circle);
      }

      const localeMap: Record<string, string> = { en: 'en-US', it: 'it-IT', es: 'es-ES', fr: 'fr-FR', pt: 'pt-BR' };
      function formatPoint(point: HistoryPoint): string {
        const d = new Date(point.date + 'T00:00:00Z');
        const dateStr = d.toLocaleDateString(localeMap[lang] || 'en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        const suffix = isInsufficient(point) ? ' (limited data)' : '';
        return `${dateStr}: ${point.score.toFixed(2)}${suffix}`;
      }

      function positionTooltip(point: HistoryPoint, rect: DOMRect): void {
        const scaleX = rect.width / viewBox.width;
        const scaleY = rect.height / viewBox.height;
        const pointCx = xScale(new Date(point.date + 'T00:00:00Z')) + margin.left;
        const pointCy = yScale(point.score) + margin.top;
        const tooltipX = pointCx * scaleX - tooltip.offsetWidth / 2;
        const tooltipY = pointCy * scaleY - tooltip.offsetHeight - 8;
        tooltip.style.left = `${Math.max(0, Math.min(tooltipX, rect.width - tooltip.offsetWidth))}px`;
        tooltip.style.top = `${Math.max(0, tooltipY)}px`;
      }

      const showTooltip = (clientX: number, _clientY: number) => {
        if (pinnedPoint) return;
        const rect = svgRect();
        const mouseX = (clientX - rect.left) / rect.width * viewBox.width - margin.left;
        const nearest = findNearestWithSnap(mouseX, currentData, currentSlopes, avgSlope);
        tooltip.textContent = formatPoint(nearest);
        tooltip.classList.remove('hidden');
        positionTooltip(nearest, rect);
        showCrosshair(nearest);
      };

      const hideTooltip = () => {
        if (pinnedPoint) return;
        tooltip.classList.add('hidden');
        hideCrosshair();
      };

      svg.addEventListener('mousemove', (e: MouseEvent) => showTooltip(e.clientX, e.clientY));
      svg.addEventListener('mouseleave', hideTooltip);

      svg.addEventListener('click', (e: MouseEvent) => {
        const rect = svgRect();
        const mouseX = (e.clientX - rect.left) / rect.width * viewBox.width - margin.left;
        if (pinnedPoint) {
          pinnedPoint = null;
          removePinnedCircle();
          tooltip.classList.add('hidden');
          hideCrosshair();
          return;
        }
        const nearest = findNearestWithSnap(mouseX, currentData, currentSlopes, avgSlope);
        pinnedPoint = nearest;
        tooltip.textContent = formatPoint(nearest);
        tooltip.classList.remove('hidden');
        positionTooltip(nearest, rect);
        showCrosshair(nearest);
        drawPinnedCircle(nearest);
      });

      svg.addEventListener('touchstart', (e: TouchEvent) => {
        e.preventDefault();
        const touch = e.touches[0];
        showTooltip(touch.clientX, touch.clientY);
      }, { passive: false });

      document.addEventListener('touchstart', (e: TouchEvent) => {
        if (!container.contains(e.target as Node)) {
          pinnedPoint = null;
          removePinnedCircle();
          hideTooltip();
        }
      });

      // Time range buttons
      let currentTimeRange = '1m';

      function filterByTimeRange(data: HistoryPoint[], range: string): HistoryPoint[] {
        if (range === 'max') return data;
        const now = new Date();
        const daysMap: Record<string, number> = { '1m': 30, '6m': 180, '1y': 365, '10y': 3650 };
        const days = daysMap[range] || 0;
        if (!days) return data;
        const cutoff = new Date(now.getTime() - days * 86400000);
        const filtered = data.filter(d => new Date(d.date + 'T00:00:00Z') >= cutoff);
        return filtered.length >= 2 ? filtered : data;
      }

      function applyTimeRange(range: string): void {
        currentTimeRange = range;
        const baseData = getChartData(currentPillar);
        const filtered = filterByTimeRange(baseData, range);

        const oldLinePath = svg.querySelector('.line-path')?.getAttribute('d') || '';
        const oldAreaPath = svg.querySelector('.area-path')?.getAttribute('d') || '';

        renderChart(filtered, baseData);
        animatePaths(oldLinePath, oldAreaPath);
        resetBtn.classList.add('hidden');

        // Update button styles
        document.querySelectorAll('.time-range-btn').forEach(btn => {
          const el = btn as HTMLElement;
          if (el.dataset.range === range) {
            el.className = 'time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-terracotta-500 text-white';
            el.setAttribute('aria-pressed', 'true');
          } else {
            el.className = 'time-range-btn px-2.5 py-1 text-xs font-medium rounded-md transition-colors cursor-pointer bg-transparent text-sand-600 dark:text-sand-300 hover:bg-sand-200 dark:hover:bg-sand-700';
            el.setAttribute('aria-pressed', 'false');
          }
        });
      }

      document.querySelectorAll('.time-range-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          applyTimeRange((btn as HTMLElement).dataset.range || 'max');
        });
      });

      // Initial render
      applyTimeRange('1m');
    }
    } // end if (container)

    }); // end import('d3').then()
  } // end initTrendChart

  // Lazy load: only initialize when chart scrolls into view
  const chartContainer = document.getElementById('trend-chart-container');
  if (chartContainer) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.disconnect();
          initTrendChart();
        }
      });
    }, { rootMargin: '200px' });

    observer.observe(chartContainer);
  }
</script>
