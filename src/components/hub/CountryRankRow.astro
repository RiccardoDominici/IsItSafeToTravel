---
import type { ScoredCountry } from '../../pipeline/types';
import type { Lang } from '../../i18n/ui';
import { routes } from '../../i18n/ui';

interface Props {
  rank: number;
  country: ScoredCountry;
  lang: Lang;
  showDelta?: boolean;
  delta?: number;
}

const { rank, country, lang, showDelta = false, delta = 0 } = Astro.props;
const r = routes[lang];
const countryUrl = `/${lang}/${r.country}/${country.iso3.toLowerCase()}/`;

function getScoreBadgeClasses(score: number): string {
  if (score >= 7) return 'bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-300';
  if (score >= 4) return 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300';
  return 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300';
}

function getDeltaClasses(d: number): string {
  if (d > 0) return 'text-emerald-600 dark:text-emerald-400';
  if (d < 0) return 'text-red-600 dark:text-red-400';
  return 'text-sand-500 dark:text-sand-400';
}
---

<a
  href={countryUrl}
  class="flex items-center gap-3 rounded-lg border border-sand-200 dark:border-sand-700 bg-white dark:bg-sand-800 px-4 py-3 hover:border-terracotta-400 dark:hover:border-terracotta-500 transition-colors"
>
  <span class="text-sm font-bold text-sand-400 dark:text-sand-500 w-8 text-right shrink-0">
    {rank}
  </span>
  <span class="text-sm font-medium text-sand-800 dark:text-sand-100 truncate flex-1">
    {country.name[lang]}
  </span>
  {showDelta && delta !== 0 && (
    <span class={`text-xs font-semibold shrink-0 ${getDeltaClasses(delta)}`}>
      {delta > 0 ? '+' : ''}{delta.toFixed(2)}
    </span>
  )}
  <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold whitespace-nowrap shrink-0 ${getScoreBadgeClasses(country.score)}`}>
    {country.score.toFixed(1)}
  </span>
</a>
