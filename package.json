{
  "name": "isitsafetotravel",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:og && npm run generate:llms && astro build && npm run validate:seo",
    "validate:seo": "npx tsx scripts/validate-seo.ts",
    "generate:og": "npx tsx scripts/generate-og-images.ts",
    "generate:llms": "npx tsx scripts/generate-llms-full.ts",
    "preview": "astro preview",
    "astro": "astro",
    "test:pipeline": "node --import tsx --test src/pipeline/scoring/__tests__/engine.test.ts",
    "test:freshness": "node --import tsx --test src/pipeline/scoring/__tests__/freshness.test.ts",
    "pipeline": "tsx src/pipeline/run.ts",
    "pipeline:date": "tsx src/pipeline/run.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.6",
    "d3": "^7.9.0",
    "fuse.js": "^7.1.0",
    "tailwindcss": "^4.2.2",
    "topojson-client": "^3.1.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/d3": "^7.4.3",
    "@types/papaparse": "^5.5.2",
    "@types/topojson-client": "^3.1.5",
    "papaparse": "^5.5.3",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  }
}
